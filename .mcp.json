{
  "mcpServers": {
    "Fundamento": {
      "type": "stdio",
      "command": "mcp-proxy",
      "args": [
        "--headers",
        "Authorization",
        "Bearer ${FUNDAMENTO_API_KEY}",
        "--transport",
        "streamablehttp",
        "https://fundamento.cloud/api/mcp"
      ]
    }
  }
}

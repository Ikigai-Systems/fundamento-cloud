#!/usr/bin/env sh

# Trap to restore cursor visibility on exit (Docker Compose can hide it)
cleanup() {
  # Restore cursor visibility and terminal state
  tput cnorm 2>/dev/null || printf '\033[?25h' || true
  stty echo 2>/dev/null || true
}
trap cleanup EXIT INT TERM

# Parse command line arguments
BUILD_FLAG=""
while [ $# -gt 0 ]; do
  case "$1" in
    --build)
      BUILD_FLAG="--build"
      shift
      ;;
    *)
      echo "Unknown option: $1"
      echo "Usage: bin/dev-e2e [--build]"
      echo ""
      echo "Options:"
      echo "  --build    Force rebuild of Docker images"
      exit 1
      ;;
  esac
done

# Load SOPS_AGE_KEY from dockerfiles/sops-age-key.secret if not already set
if [ -z "$SOPS_AGE_KEY" ]; then
  if [ -f dockerfiles/sops-age-key.secret ]; then
    echo "Loading SOPS_AGE_KEY from dockerfiles/sops-age-key.secret..."
    echo ""
    export SOPS_AGE_KEY=$(grep -v '^#' dockerfiles/sops-age-key.secret | grep -v '^$' | head -n 1)
  else
    echo "❌ Error: SOPS_AGE_KEY is not set and dockerfiles/sops-age-key.secret not found!"
    echo ""
    echo "SOPS_AGE_KEY is required to decrypt secrets for the E2E environment."
    echo ""
    echo "Options:"
    echo "  1. Run bin/setup to import it from 1password vault"
    echo "  2. Export it in your shell: export SOPS_AGE_KEY='your-key-here'"
    echo "  3. Pass it inline: SOPS_AGE_KEY='your-key' bin/dev-e2e"
    echo ""
    exit 1
  fi
fi

# Set E2E environment variables (offset ports by +1000)
export RAILS_ENV=e2e
export RAILS_PORT=4000
export RAILS_LOG_LEVEL=debug
export POSTGRES_PORT=6432
export REDIS_PORT=7379
export MINIO_PORT=10000
export MINIO_CONSOLE_PORT=10001
export BLOCKNOTE_PORT=4002
export HTTP_HOST=localhost:4000

echo "Starting E2E test environment with offset ports..."
echo "  Rails: http://localhost:${RAILS_PORT}"
echo "  MinIO Console: http://localhost:${MINIO_CONSOLE_PORT}"
echo "  PostgreSQL: localhost:${POSTGRES_PORT}"
echo "  Redis: localhost:${REDIS_PORT}"
echo ""

# Fix local file permissions before Docker build
# Docker COPY preserves source permissions, so restrictive local perms (600) cause access issues
echo "Checking file permissions..."
FIXED_FILES=$(find . -type f \( -name "*.rb" -o -name "*.erb" -o -name "*.rake" -o -name "*.js" -o -name "*.ts" -o -name "*.yml" \) \
  ! -path "*/node_modules/*" \
  ! -path "*/vendor/*" \
  ! -path "*/.git/*" \
  ! -perm -044 \
  2>/dev/null)

if [ -n "$FIXED_FILES" ]; then
  FILE_COUNT=$(echo "$FIXED_FILES" | wc -l | tr -d ' ')
  echo "⚠️  Found $FILE_COUNT file(s) with restrictive permissions (not world-readable)"
  echo "$FIXED_FILES" | head -5
  if [ "$FILE_COUNT" -gt 5 ]; then
    echo "   ... and $((FILE_COUNT - 5)) more"
  fi
  echo ""
  echo "Fixing permissions to 644 (readable by all, writable by owner)..."
  echo "$FIXED_FILES" | xargs chmod 644
  echo "✓ Fixed permissions for $FILE_COUNT file(s)"
  echo ""
fi

if [ -n "$BUILD_FLAG" ]; then
  echo "Rebuilding Docker images..."
else
  echo "Starting Docker Compose services..."
fi

# Start all E2E services with -p flag for isolation and wait for them to be healthy
# Use --ansi never to prevent terminal escape sequences that can corrupt terminal state
docker compose --ansi never -p e2e-tests up $BUILD_FLAG --wait

echo ""
echo "✓ E2E environment is ready!"
echo ""
echo "Next steps:"
echo "  Run tests:  npx cypress run --project spec/e2e"
echo "  Open UI:    npx cypress open --project spec/e2e"
echo "  Stop:       docker compose -p e2e-tests down"
echo "  Cleanup:    docker compose -p e2e-tests down --volumes"

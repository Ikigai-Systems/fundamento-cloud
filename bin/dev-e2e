#!/usr/bin/env ruby
require "bundler/setup"
require "thor"

class DevE2E < Thor
  PROJECT = "e2e-tests"
  WEBSITE_CONTAINER = "website"

  ENV_VARS = {
    "RAILS_ENV" => "e2e",
    "RAILS_PORT" => "4000",
    "RAILS_LOG_LEVEL" => "debug",
    "POSTGRES_PORT" => "6432",
    "REDIS_PORT" => "7379",
    "MINIO_PORT" => "10000",
    "MINIO_CONSOLE_PORT" => "10001",
    "BLOCKNOTE_PORT" => "4002",
    "HTTP_HOST" => "localhost:4000",
  }.freeze

  default_command :up

  desc "up", "Start the E2E test environment (default command)"
  option :build, type: :boolean, default: true, desc: "Build Docker images before starting"
  option :test, type: :boolean, default: false, desc: "Run Cypress tests after environment is healthy"
  def up
    setup_env!
    load_rails_master_key!
    print_status

    compose("down")

    if options[:build]
      fix_permissions!
      puts "Rebuilding Docker images..."
    else
      puts "Starting Docker Compose services..."
    end

    build_args = options[:build] ? ["--build"] : []
    success = with_terminal_cleanup do
      compose("up", *build_args, "--wait")
    end

    unless success
      abort "\nFailed to start E2E environment."
    end

    puts ""
    puts "E2E environment is ready!"
    puts ""

    if options[:test]
      run_cypress
    else
      print_hints
    end
  end

  desc "down", "Stop E2E containers"
  def down
    setup_env!
    compose("down")
  end

  desc "clean", "Remove all containers, volumes, and local images"
  def clean
    setup_env!
    puts "Removing all E2E containers, volumes, and local images..."
    compose("down", "--volumes", "--remove-orphans", "--rmi", "local")
    puts "Clean complete."
  end

  desc "logs", "Stream docker compose logs (Ctrl-C to exit)"
  def logs
    setup_env!
    exec_compose("logs", "-f")
  end

  desc "console", "Rails console in the website container"
  def console
    setup_env!
    exec_in_container("bin/rails", "console")
  end

  desc "shell", "Bash shell in the website container"
  map "shell" => :open_shell
  def open_shell
    setup_env!
    exec_in_container("bash")
  end

  desc "test", "Run Cypress tests (assumes environment already running)"
  def test
    run_cypress
  end

  private

  def setup_env!
    ENV_VARS.each { |key, value| ENV[key] = value }
  end

  def load_rails_master_key!
    return if ENV["RAILS_MASTER_KEY"] && !ENV["RAILS_MASTER_KEY"].empty?

    # Try reading from the key file first
    key_file = File.join(Dir.pwd, "config", "credentials", "e2e.key")
    if File.exist?(key_file)
      key = File.read(key_file).strip
      if !key.empty?
        puts "Loading RAILS_MASTER_KEY from config/credentials/e2e.key..."
        puts ""
        ENV["RAILS_MASTER_KEY"] = key
        return
      end
    end

    # Fall back to extracting from SOPS
    sops_file = File.join(Dir.pwd, "config", "secrets", "e2e.sops.yaml")

    unless File.exist?(sops_file)
      abort <<~MSG
        Error: Neither config/credentials/e2e.key nor config/secrets/e2e.sops.yaml found!

        Run bin/setup to extract credential keys from SOPS.
      MSG
    end

    puts "Extracting RAILS_MASTER_KEY from SOPS for e2e environment..."
    puts ""

    key = `sops -d --extract '["rails"]["master_key"]' #{sops_file} 2>/dev/null`.strip

    if $?.success? && !key.empty?
      ENV["RAILS_MASTER_KEY"] = key
    else
      abort <<~MSG
        Error: Failed to extract rails master key from #{sops_file}

        Ensure your age key is configured at ~/.config/sops/age/keys.txt
      MSG
    end
  end

  def fix_permissions!
    puts "Checking file permissions..."

    extensions = %w[rb erb rake js ts yml]
    pattern = extensions.map { |ext| "-name '*.#{ext}'" }.join(" -o ")
    excludes = "-not -path '*/node_modules/*' -not -path '*/vendor/*' -not -path '*/.git/*'"

    files = `find . -type f \\( #{pattern} \\) #{excludes} ! -perm -044 2>/dev/null`.strip

    return if files.empty?

    file_list = files.split("\n")
    count = file_list.size

    puts "Found #{count} file(s) with restrictive permissions (not world-readable)"
    file_list.first(5).each { |f| puts "  #{f}" }
    puts "   ... and #{count - 5} more" if count > 5
    puts ""
    puts "Fixing permissions to 644 (readable by all, writable by owner)..."

    file_list.each { |f| File.chmod(0644, f) }

    puts "Fixed permissions for #{count} file(s)"
    puts ""
  end

  def compose(*args)
    cmd = ["docker", "compose", "--ansi", "never", "-p", PROJECT, *args]
    system(*cmd)
  end

  def exec_compose(*args)
    Kernel.exec("docker", "compose", "--ansi", "never", "-p", PROJECT, *args)
  end

  def exec_in_container(*command)
    container_id = `docker compose -p #{PROJECT} ps -q #{WEBSITE_CONTAINER}`.strip

    if container_id.empty?
      abort "Error: #{WEBSITE_CONTAINER} container is not running. Start with: bin/dev-e2e up"
    end

    Kernel.exec("docker", "exec", "-it", container_id, *command)
  end

  def with_terminal_cleanup
    yield
  ensure
    system("tput cnorm 2>/dev/null || printf '\\033[?25h' || true")
    system("stty echo 2>/dev/null || true")
  end

  def run_cypress
    system("npx", "cypress", "run", "--project", "spec/e2e")
    exit($?.exitstatus || 1)
  end

  def print_status
    puts "Starting E2E test environment with offset ports..."
    puts "  Rails:         http://localhost:#{ENV['RAILS_PORT']}"
    puts "  MinIO Console: http://localhost:#{ENV['MINIO_CONSOLE_PORT']}"
    puts "  PostgreSQL:    localhost:#{ENV['POSTGRES_PORT']}"
    puts "  Redis:         localhost:#{ENV['REDIS_PORT']}"
    puts ""
  end

  def print_hints
    puts "Quick commands:"
    puts "  Run tests:  bin/dev-e2e test"
    puts "  Open UI:    npx cypress open --project spec/e2e"
    puts "  Logs:       bin/dev-e2e logs"
    puts "  Console:    bin/dev-e2e console"
    puts "  Shell:      bin/dev-e2e shell"
    puts "  Stop:       bin/dev-e2e down"
    puts "  Cleanup:    bin/dev-e2e clean"
  end
end

DevE2E.start(ARGV)

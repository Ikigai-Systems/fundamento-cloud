#!/bin/bash -e

# Auto-generate secret key for standalone on first boot
if [ "$RAILS_ENV" = "standalone" ]; then
  SECRET_KEY_BASE_FILE=config/credentials/secret_key_base
  if [ ! -f "$SECRET_KEY_BASE_FILE" ]; then
    echo "First boot detected — generating secret key..."
    ./bin/rails secret > "$SECRET_KEY_BASE_FILE"
  fi
fi

if [ "${1}" == "./bin/rails" ] && [ "${2}" == "server" ]; then
  ./bin/rails db:prepare
fi

exec "${@}"

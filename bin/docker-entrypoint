#!/bin/bash -e

# Auto-generate credentials for standalone on first boot
if [ "$RAILS_ENV" = "standalone" ]; then
  CREDENTIALS_FILE=config/credentials/standalone.yml.enc

  if [ ! -f "$CREDENTIALS_FILE" ]; then
    echo "First boot detected — generating standalone credentials..."
    EDITOR="true" ./bin/rails credentials:edit --environment standalone
  fi
fi

if [ "${1}" == "./bin/rails" ] && [ "${2}" == "server" ]; then
  ./bin/rails db:prepare
fi

exec "${@}"

#!/bin/bash
# Local Docker build matching CI workflow
# This script replicates the docker/build-push-action@v6 behavior from GitHub Actions

set -e

# Color output
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

# Parse arguments
PUSH=false
TARGET="production"
for arg in "$@"; do
  case "$arg" in
    --push) PUSH=true ;;
    --*) echo -e "${RED}Unknown option: ${arg}${NC}"; exit 1 ;;
    *) TARGET="$arg" ;;
  esac
done

RAILS_ENV="${RAILS_ENV:-production}"

echo -e "${GREEN}Building Docker image for target: ${TARGET}${NC}"
echo "Using RAILS_ENV: ${RAILS_ENV}"

if [ "$PUSH" = true ]; then
  echo "Mode: pushing the image to GitHub repository (linux/amd64 → ghcr.io)"
else
  echo "Mode: building the image for local consumption (native arch → local daemon)"
fi
echo ""

SECRET_FILE="dockerfiles/fontawesome-auth.secret"
if [ ! -f "$SECRET_FILE" ]; then
  echo -e "${RED}Error: ${SECRET_FILE} not found${NC}"
  echo "Run: sops -d --extract '[\"fontawesome\"][\"auth_token\"]' config/secrets/${RAILS_ENV}.sops.yaml > ${SECRET_FILE}"
  exit 1
fi

if [ "$PUSH" = true ]; then
  TIMESTAMP=$(date -u +"%Y-%m-%dT%H-%M-%S.000Z")
  GIT_SHA=$(git rev-parse --short HEAD)
  REGISTRY="ghcr.io/ikigai-systems/fundamento-cloud"

  echo -e "${YELLOW}Setting up buildx for cross-platform build...${NC}"
  docker buildx inspect fundamento-amd64 > /dev/null 2>&1 \
    || docker buildx create --name fundamento-amd64 --driver docker-container --bootstrap

  echo -e "${YELLOW}Building and pushing linux/amd64 image...${NC}"
  docker buildx build \
    --builder fundamento-amd64 \
    --file Dockerfile \
    --target "${TARGET}" \
    --platform linux/amd64 \
    --build-arg RAILS_ENV="${RAILS_ENV}" \
    --build-arg NODE_MAJOR=24 \
    --secret id=fontawesome-auth,src="${SECRET_FILE}" \
    --tag "${REGISTRY}:${TIMESTAMP}" \
    --tag "${REGISTRY}:sha-${GIT_SHA}" \
    --push \
    .

  echo ""
  echo -e "${GREEN}Build and push complete!${NC}"
  echo "Timestamp tag: ${REGISTRY}:${TIMESTAMP}"
  echo "SHA tag:       ${REGISTRY}:sha-${GIT_SHA}"
  echo ""
  echo "FluxCD will pick up the timestamp tag automatically."
else
  echo -e "${YELLOW}Building with docker buildx...${NC}"
  docker buildx build \
    --file Dockerfile \
    --target "${TARGET}" \
    --build-arg RAILS_ENV="${RAILS_ENV}" \
    --build-arg NODE_MAJOR=24 \
    --secret id=fontawesome-auth,src="${SECRET_FILE}" \
    --tag "fundamento-cloud:${TARGET}" \
    --load \
    .

  echo ""
  echo -e "${GREEN}Build complete!${NC}"
  echo "Image: fundamento-cloud:${TARGET}"
  echo ""
  echo "To run with docker-compose:"
  echo "  export RAILS_MASTER_KEY=\$(sops -d --extract '[\"rails\"][\"master_key\"]' config/secrets/${RAILS_ENV}.sops.yaml)"
  echo "  docker-compose up"
  echo ""
  echo "Or run standalone:"
  echo "  docker run -p 3000:3000 -e RAILS_MASTER_KEY=\"\$(sops -d --extract '[\"rails\"][\"master_key\"]' config/secrets/${RAILS_ENV}.sops.yaml)\" fundamento-cloud:${TARGET}"
fi

<%= turbo_frame_tag :connections_sidebar_tab do %>
  <div class="flex flex-col gap-3 p-3">
    <% if @incoming.present? %>
      <div>
          <i class="fa-regular fa-arrow-left"></i>
          <span>Referenced in:</span>
      </div>
    <% end %>

    <% @incoming.sort_by(&:object_title).reverse.each do |reference| %>
      <div class="flex flex-row gap-3 items-center">
        <%= render ObjectIcon.new(object: reference.referenced_by) %>

        <div class="text-base truncate">
          <%= link_to reference.referenced_by.try(:title_emojiless) || reference.referenced_by.try(:title), reference.referenced_by %>
        </div>
      </div>
    <% end %>

    <% if @outgoing.present? %>
      <div>
        <i class="fa-regular fa-arrow-right"></i>
        <span>References:</span>
      </div>
    <% end %>

    <% @outgoing.sort_by(&:object_title).reverse.each do |reference| %>
      <div class="flex flex-row gap-3 items-center">
        <%= render ObjectIcon.new(type: reference.object_type, emoji: reference.try(:object_title_emoji)) %>

        <div class="text-base truncate">
          <%= link_to reference.try(:object_title_emojiless) || reference.try(:object_title), reference.object_path %>
        </div>
      </div>
    <% end %>

    <% if @incoming.empty? && @outgoing.empty? %>
      No references were found.
    <% end %>
  </div>
<% end %>

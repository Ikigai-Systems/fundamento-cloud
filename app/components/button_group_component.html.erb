<% random_id = SecureRandom.hex(10) %>

<div class="inline-flex rounded-md shadow-sm">

  <%= primary_buttons %>

  <div
    data-controller="dropdown"
    data-action="click@window->dropdown#hide touchstart@window->dropdown#hide keydown.up->dropdown#previousItem keydown.down->dropdown#nextItem keydown.esc->dropdown#hide"
    class="relative -ml-px block">

    <button
      id="<%= random_id %>"
      class="relative inline-flex items-center rounded-r-md bg-white px-2 py-2 text-gray-400 ring-1 ring-inset ring-gray-300 hover:bg-gray-50 focus:z-10 dark:!bg-gray-800 dark:ring-gray-600 dark:text-gray-400 dark:hover:text-white dark:hover:!bg-gray-700 dark:hover:text-gray-50"
      aria-expanded="true"
      aria-haspopup="true"
      data-action="dropdown#toggle:stop"
    >
      <span class="sr-only">Open options</span>

      <svg class="h-5 w-5" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
        <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
      </svg>
    </button>

    <div
      data-dropdown-target="menu"
      class="hidden absolute top-5 right-0 z-10 mt-5 flex w-screen max-w-max"
      role="menu"
      aria-orientation="vertical"
      aria-labelledby="<%= random_id %>"
      tabindex="-1">
      <div class="dropdown-container w-32" role="menu">
        <%= dropdown_menu %>
      </div>
    </div>
  </div>

</div>
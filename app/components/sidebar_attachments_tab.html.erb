<%= turbo_frame_tag :attachments_sidebar_tab do %>
  <div class="flex flex-col gap-3 p-3">
    <% if @attachments.any? %>
      <% @attachments.each do |attachment| %>
        <div class="flex flex-row gap-3 items-start justify-between">
          <div class="flex flex-col gap-1 flex-1 min-w-0">
            <%= link_to attachment_path(attachment), data: { turbo_frame: "_top" }, class: "text-base truncate hover:underline" do %>
              <i class="fa-regular fa-paperclip"></i>
              <%= attachment.filename %>
            <% end %>
            <div class="text-sm text-gray-500">
              <%= time_ago_in_words(attachment.created_at) %> ago
            </div>
          </div>

          <% if @can_update %>
            <%= button_to attachment_path(attachment),
              method: :delete,
              class: "text-red-500 hover:text-red-700",
              form: {
                data: {
                  turbo_confirm: "Are you sure you want to delete this attachment?"
                }
              } do %>
              <i class="fa-regular fa-trash"></i>
            <% end %>
          <% end %>
        </div>
      <% end %>
    <% else %>
      <div class="text-gray-500">No attachments found.</div>
    <% end %>
  </div>
<% end %>

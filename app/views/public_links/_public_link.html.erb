<tr id="<%= dom_id(public_link) %>" class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600">
  <th scope="row" class="flex items-center px-6 py-4 text-gray-900 whitespace-nowrap dark:text-white">
    <div class="ps-3">
      <div class="text-base font-semibold">
        <%=
          link_to(public_link.object) do
            public_link.object.title
          end
        %>
      </div>
      <div class="font-normal text-gray-500">
        Shared by <%= link_to public_link.updated_by.display_name, public_link.updated_by %>
      </div>
    </div>
  </th>
  <td class="px-6 py-4">
    <%= link_to "Public Link", "/public/#{public_link.npi}" %>
  </td>
  <td class="px-6 py-4">
    <%= button_to "Refresh", public_link_path(public_link), method: :patch, form: { data: { turbo_confirm: "Are you sure? Previous public link will stop working immediately!" } }, class: "font-medium text-blue-600 dark:text-blue-500 hover:underline" %>

    <%= button_to "Delete", public_link_path(public_link), method: :delete, form: { data: { turbo_confirm: "Are you sure? Public link will be removed immediately!" } }, class: "font-medium text-blue-600 dark:text-blue-500 hover:underline" %>
  </td>
</tr>


<div class="bg-white shadow sm:rounded-lg">
  <div class="px-4 py-5 sm:p-6">
    <h3 class="text-base font-semibold leading-6 text-gray-900">Share this document</h3>
    <div class="mt-2 max-w-xl text-sm text-gray-500">
      <p>
        This document is available for public access using this link:
      </p>
      <div class="my-2">
        <code>
          <%= url_for(controller: "public", action: "show", npi: public_link.npi, host: request.host, protocol: request.protocol) %>
        </code>
      </div>
      <p>
        You can see all documents shared publicly
        <%= link_to "here", public_links_path %>.
      </p>
    </div>
    <div class="mt-5 inline-flex">
      <%= button_to "Refresh", public_link_path(public_link), method: :patch, form: { data: { turbo_confirm: "Are you sure? Previous public link will stop working immediately!" } }, class: "secondary-button mr-2" %>

      <%= button_to "Delete", public_link_path(public_link), method: :delete, form: { data: { turbo_confirm: "Are you sure? Public link will be removed immediately!" } }, class: "secondary-button" %>
    </div>
  </div>
</div>
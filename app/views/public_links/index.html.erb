<%= turbo_stream_from ["public_links_list", current_user] %>

<% content_for :focused_header do %>
  Public Links
<% end %>

<% content_for :focused_content do %>
  <div class="table-legend">
    <div class="table-legend-description">
      <p>A list of all public links created in your organization. Everyone having a link can access it.</p>
    </div>
  </div>

  <table class="table-list">
    <thead>
      <tr>
        <th scope="col">
          Document
        </th>
        <th scope="col">
          Public Link
        </th>
        <th scope="col">
          Actions
        </th>
      </tr>
    </thead>
    <tbody id="organizations">
      <% @public_links.each do |public_link| %>
        <%= render partial: public_link %>
      <% end %>
    </tbody>
  </table>
<% end %>

<%= render "focused_section" %>
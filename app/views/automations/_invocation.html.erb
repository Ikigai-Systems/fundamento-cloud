<tr id="<%= dom_id(automation_invocation) %>">
  <th scope="row">
    <div>
      <div class="text-base font-semibold"><%= automation_invocation.invoked_at.presence || automation_invocation.created_at %></div>
      <div class="font-normal text-gray-500"><%= time_ago_in_words automation_invocation.invoked_at.presence || automation_invocation.created_at %></div>

      <% if automation_invocation.invoked_at.blank? %>
        (Queued)
      <% end %>
    </div>
  </th>
  <td>
    <%= automation_invocation.result %>
  </td>
  <td>
    <%= automation_invocation.webhook? && automation_invocation.formula %>
  </td>
</tr>
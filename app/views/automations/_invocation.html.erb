<tr id="<%= dom_id(invocation) %>">
  <th scope="row">
    <div>
      <div class="text-base font-semibold"><%= invocation.invoked_at %></div>
      <div class="font-normal text-gray-500"><%= time_ago_in_words invocation.invoked_at %></div>
    </div>
  </th>
  <td>
    <%= invocation.result %>
  </td>
  <td>
    <%= invocation.webhook? && invocation.formula %>
  </td>
</tr>
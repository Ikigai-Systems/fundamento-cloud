<section class="form-section">
  <h2 class="form-header">Edit automation <%= @automation.title %></h2>

  <%= form_for(@automation,
    url: space_automation_path(@automation.space, @automation),
    html: { class: "default-form" },
    data: { turbo: false, controller: "prevent-double-submit"  }) do |f|
  %>
    <%= render "devise/shared/error_messages", resource: @automation %>

    <div class="form-field">
      <%= f.label :title %>
      <%= f.text_field :title, autofocus: true, class: "form-input" %>
    </div>

    <div class="form-field">
      <%= f.label :kind %>
      <%= @automation.kind %>
    </div>

    <div class="form-field">
      <%= f.label :formula %>
      <%= f.text_area :formula, class: "form-input" %>
    </div>

    <div class="form-footer">
      <%= link_to "Cancel", space_automation_path(@automation.space, @automation), class: "secondary-button" %>
      <%= f.submit "Save", class: "form-submit" %>
    </div>
  <% end %>
</section>
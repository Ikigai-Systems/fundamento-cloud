<%= turbo_stream_from ["team_users_list", @team] %>

<% content_for :focused_breadcrumbs do %>
  <li>
    <div class="flex">
      <a href="#" class="text-sm font-medium text-gray-500 hover:text-gray-700">
        <%= link_to "Teams", teams_path %>
      </a>
    </div>
  </li>
<% end %>

<% content_for :focused_header do %>
  <%= @team.name %>
<% end %>

<% content_for :focused_header_buttons do %>
  <% if policy(@team).update? && policy(@team).destroy? %>
    <div class="mt-4 flex md:ml-4 md:mt-0">
      <% content_for :button_group_primary_buttons do %>
        <%= link_to 'Edit', edit_team_path(@team), class: "first-button-group" %>
      <% end %>

      <% content_for :button_group_dropdown_menu do %>
        <%= button_to "Delete", team_path(@team), form: { data: { turbo_confirm: "Are you sure? Your team will be immediately removed!" } }, data: {"dropdown-target" => "menuItem"}, role: "menuitem", tabindex: "-1", method: :delete %>
      <% end %>

      <%= render template: "application/components/button_group"%>
    </div>
  <% end %>
<% end %>

<% content_for :focused_content do %>
  <div class="table-legend">
    <div class="table-legend-description">
      <h1>Users</h1>
      <p>A list of all the users in your team.</p>
    </div>
  </div>

  <table class="table-list">
    <thead>
    <tr>
      <th scope="col">
        Name
      </th>
      <th scope="col">
        Status
      </th>
    </tr>
    </thead>
    <tbody id="team_members">
    <% @team.team_memberships.each do |membership| %>
      <%= render partial: "teams/user", locals: { user: membership.member.user, team: @team } %>
    <% end %>
    </tbody>
  </table>
<% end %>

<%= render partial: "focused_section" %>
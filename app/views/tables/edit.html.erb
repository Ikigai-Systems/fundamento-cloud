<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<% content_for :content_menu do %>
  <%= link_to table_path(@table),
    class: "link-button" do %>
    <i class="fa-regular fa-turn-left"></i>
  <% end %>

  <%= render partial: "content/document_menu", locals: { space: @space, content: @table } %>
<% end %>

<article class="document document-editable">
  <%= react_component "EditTablePanel", {
    table: @table,
    space: @table.space.to_react_props
  }, {
    data: @table.data_to_json(
      evaluate_formulas: true,
      evaluate_as: current_organization_membership,
    )
  } %>

  <p class="mx-auto p-3 text-sm">
    <i class="fa-solid fa-circle-info"></i>
    Changes are saved automatically
  </p>
</article>

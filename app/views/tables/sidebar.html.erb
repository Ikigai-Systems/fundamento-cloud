<%= turbo_frame_tag :content_sidebar do %>
  <div
    class="content-sidebar-tabs"
    data-controller="tabs"
    data-tabs-active-tab-class="active-tab"
  >
    <div class="border-b">
      <nav data-tabs-target="list" aria-label="Tabs">
        <button id="details" data-action="click->tabs#change" data-tabs-target="tab">
          <%= render SidebarTabIcon.new(tooltip: "Details") do %>
            <i class="fa-regular fa-memo-circle-info"></i>
          <% end %>
        </button>

        <button id="visitors" data-action="click->tabs#change" data-tabs-target="tab">
          <%= render SidebarTabIcon.new(tooltip: "Visitors") do %>
            <i class="fa-regular fa-screen-users"></i>
          <% end %>
        </button>

        <button id="connections" data-action="click->tabs#change" data-tabs-target="tab">
          <%= render SidebarTabIcon.new(tooltip: "Connections") do %>
            <i class="fa-regular fa-chart-network"></i>
          <% end %>
        </button>
      </nav>
    </div>

    <div data-tabs-target="panel" class="hidden max-h-0">
      <%= turbo_frame_tag "details_sidebar_tab", loading: "lazy", data: { turbo: false }, src: polymorphic_path([:sidebar, @table], tab: :details) do %>
        <%= render SidebarLoadingComponent.new %>
      <% end %>
    </div>

    <div data-tabs-target="panel" class="hidden max-h-0">
      <%= turbo_frame_tag "visitors_sidebar_tab", loading: "lazy", data: { turbo: false }, src: polymorphic_path([:sidebar, @table], tab: :visitors) do %>
        <%= render SidebarLoadingComponent.new %>
      <% end %>
    </div>

    <div data-tabs-target="panel" class="hidden max-h-0">
      <%= turbo_frame_tag "connections_sidebar_tab", loading: "lazy", data: { turbo: false }, src: polymorphic_path([:sidebar, @table], tab: :connections) do %>
        <%= render SidebarLoadingComponent.new %>
      <% end %>
    </div>
  </div>
<% end %>

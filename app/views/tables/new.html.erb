<section class="form-section">
  <h2 class="form-header">Create table</h2>

  <%= form_for("table", url: tables_path,
    html: { class: "default-form" },
    data: { turbo: false, controller: "prevent-double-submit" }) do |f|
  %>
    <%= f.hidden_field :space_npi, value: @space.id %>

    <%= render "devise/shared/error_messages", resource: @table %>

    <div class="form-field">
      <%= f.label :name %>
      <%= f.text_field :name, autofocus: true, class: "form-input" %>
    </div>

    <div class="form-field">
      <%= f.label :csv, "Import from csv file (optional)", class: "block" %>
      <%= f.file_field :csv_file, accept: "text/csv", class: "mt-1" %>
    </div>

    <div class="form-footer">
      <%= link_to "Cancel", space_path(@space), class: "secondary-button" %>
      <%= f.submit "Create", class: "form-submit" %>
    </div>
  <% end %>
</section>
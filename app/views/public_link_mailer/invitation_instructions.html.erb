<!-- Title -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td style="padding-bottom: 17px;">
      <h1 style="margin: 0; font-family: Inter, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size: 24px; font-weight: 500; color: #111111; text-align: center; line-height: 28px; letter-spacing: -1.2px;">
        <%= @pundit_user.organization_user.display_name %> invited you to review a document titled <strong><%= @public_link.object.title %></strong>.
      </h1>
    </td>
  </tr>
</table>

<!-- Profile Message -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td style="padding-bottom: 40px;">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
        <tr>
          <td style="width: 32px; vertical-align: top;">
            <table role="presentation" width="32" height="32" cellpadding="0" cellspacing="0" border="0" style="background-color: #3b82f6; border-radius: 50%; mso-border-radius-alt: 16px;">
              <tr>
                <td align="center" valign="middle" style="font-family: Inter, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size: 15px; font-weight: 700; color: white; text-align: center; letter-spacing: -0.6px; line-height: 32px;">
                  <%= @pundit_user.organization_user.initials %>
                </td>
              </tr>
            </table>
          </td>
          <td style="padding-left: 16px; vertical-align: top;">
            <p style="margin: 0; font-family: Inter, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size: 15px; font-weight: 500; color: #424040; line-height: 22px; letter-spacing: -0.6px;">
              I've just shared a document with you using Fundamento platform where we can collaborate on our documents. Let's get started!
            </p>
          </td>
        </tr>
      </table>
    </td>
  </tr>
</table>

<!-- Accept Button -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td align="center" style="padding-bottom: 28px;">
      <%= link_to "Sign up or sign in to access the document", public_link_url(@public_link), style: 'display: inline-block; padding: 12px 24px; background-color: #fb923c; color: #0f172a; text-decoration: none; border-radius: 8px; font-family: Inter, BlinkMacSystemFont, "Segoe UI", "Helvetica Neue", Arial, sans-serif; font-size: 15px; font-weight: 700; letter-spacing: -0.5px; text-align: center;' %>
    </td>
  </tr>
</table>

<!-- Ignore Message -->
<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0">
  <tr>
    <td>
      <p style="margin: 12px 0 0 0; font-family: Inter, BlinkMacSystemFont, 'Segoe UI', 'Helvetica Neue', Arial, sans-serif; font-size: 13px; font-weight: 500; color: #aaa; line-height: 20px; letter-spacing: -0.6px;">
        <%= t("devise.mailer.invitation_instructions.ignore") %>
      </p>
    </td>
  </tr>
</table>
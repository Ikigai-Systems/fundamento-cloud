<!DOCTYPE html>
<html>
<head>
  <title>Fundamento</title>

  <link rel="icon" href="<%= image_path "fundamento-logo-color-flat.svg" %>" type="image/svg+xml">

  <meta name="viewport" content="width=device-width,initial-scale=1">

  <%= csrf_meta_tags %>
  <%= csp_meta_tag %>

  <%= stylesheet_link_tag "tailwind", "inter-font", "data-turbo-track": "reload" %>
  <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
</head>
<%= tag.body class: "min-h-screen flex items-center justify-center bg-gray-100 dark:bg-gray-900" do %>
  <%= yield %>
<% end %>
</html>

<%= render "layouts/body", body_class: "overflow-hidden content-container" do %>
  <div class="h-screen">
    <div class="h-full grid grid-cols-[min-content_minmax(200px,_3fr)_min-content]">
      <%= render "application/left_sidebar" %>

      <div class="h-screen content-container flex flex-col">
        <nav class="w-full flex justify-end p-3 gap-1 items-center min-h-15 max-h-15 border-b">
          <%= content_for :content_menu %>

          <%= render "application/notifications_menu" %>

          <div class="mx-1">
            <%= render "application/user_menu" %>
          </div>
        </nav>

        <div class="overflow-y-auto pt-1">
          <%= yield %>
        </div>
      </div>

      <%= tag.aside(
        id: "content-sidebar",
        class: {
          "content-sidebar sidebar w-[320px] group/collapser [&.collapsed]:w-5" => true,
          "collapsed" => cookies["ikigai_userPreferences_contentSideBarExpanded"] == "false",
        },
        data: {
          "controller" => "cookie-controlled-toggle",
          "cookie-controlled-toggle-cookie-key-value" => "ikigai_userPreferences_contentSideBarExpanded",
          "cookie-controlled-toggle-target" => "toggleable",
          "toggle-class" => "collapsed",
          "cookie-controlled-toggle-open-value" => !(cookies["ikigai_userPreferences_contentSideBarExpanded"] == "false"),
        }) do
      %>
        <div class="relative z-10">
          <div class="sidebar-collapse-trigger -left-3.5 group-[.collapsed]/collapser:left-1"
               data-controller="hotkey popover"
               data-hotkey="]"
               data-action="click->cookie-controlled-toggle#toggle touch->cookie-controlled-toggle#toggle mouseenter->popover#show mouseleave->popover#hide"
          >
            <span class="icon-[heroicons--chevron-right-16-solid] size-4 ml-1.5 mt-[4px] block group-[.collapsed]/collapser:hidden"></span>
            <span class="icon-[heroicons--chevron-left-16-solid] size-4 ml-1.5 mt-[4px] hidden group-[.collapsed]/collapser:block"></span>

            <template data-popover-target="content">
              <div data-popover-target="card" class="popover-tooltip-card w-24 flex flex-row items-center justify-center group-[:not(.collapsed)]/collapser:!left-8 group-[.collapsed]/collapser:right-8 -top-1">
                <p class="block group-[.collapsed]/collapser:hidden">Collapse <code>]</code></p>
                <p class="hidden group-[.collapsed]/collapser:block">Expand <code>]</code></p>
              </div>
            </template>
          </div>
        </div>

        <div class="sidebar-internal">
          <% if content_for?(:content_sidebar) %>
            <%= content_for :content_sidebar %>
          <% else %>
            <%
              if defined?(@document)
                object = @document
              elsif defined?(@table)
                object = @table
              end
            %>

            <div class="m-5 rounded-xl drop-shadow-lg sidebar-colors grow">
              <%= turbo_frame_tag "content_sidebar", data: { turbo: false }, src: polymorphic_path([:sidebar, object]) do %>
                <%= render Object::SidebarLoadingComponent.new %>
              <% end %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>

  <div id="flashes" class="fixed top-0 w-full flex flex-col items-end pointer-events-none">
    <%= render partial: "flash_messages_as_alerts" %>
  </div>
<% end %>

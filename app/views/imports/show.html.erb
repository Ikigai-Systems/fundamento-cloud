<%= turbo_stream_from ["document_import", @document_import] %>

<% content_for :focused_header do %>
  Document is being imported
<% end %>

<% content_for :focused_content do %>
  <div class="import-details">
    <div class="form-field">
      <label>File:</label>
      <div><%= @document_import.filename %></div>
    </div>

    <div class="form-field">
      <label>Space:</label>
      <div><%= link_to @document_import.space.name, space_path(@document_import.space) %></div>
    </div>

    <div class="form-field">
      <label>Imported by:</label>
      <div><%= @document_import.organization_user.display_name %></div>
    </div>

    <div class="form-field">
      <label>Created:</label>
      <div><%= @document_import.created_at.strftime("%B %d, %Y at %I:%M %p") %></div>
    </div>

    <div class="form-field">
      <label>Status:</label>
      <div>
        <% if @document_import.successful? %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
            ✓ Completed
          </span>
        <% else %>
          <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
            ⏳ Processing...
          </span>
        <% end %>
      </div>
    </div>

    <% if @document_import.successful? %>
      <div class="form-field">
        <label>Created Document:</label>
        <div><%= link_to @document_import.document.title, document_path(@document_import.document), class: "link" %></div>
      </div>
    <% end %>
  </div>

  <div class="form-footer">
    <%= link_to "Back to Imports", imports_path, class: "btn btn-secondary" %>
    <% if @document_import.successful? %>
      <%= link_to "View Document", document_path(@document_import.document), class: "btn btn-primary" %>
    <% end %>
  </div>
<% end %>

<%= render "focused_section" %>
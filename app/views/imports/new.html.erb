<section class="form-section">
  <h2 class="form-header">Import Document</h2>

  <%= form_for(@document_import,
    url: imports_path,
    html: { class: "default-form", enctype: "multipart/form-data" },
    data: { turbo: false, controller: "prevent-double-submit" }) do |f|
  %>
    <%= render "devise/shared/error_messages", resource: @document_import %>

    <div class="form-field">
      <%= f.label :space_id, "Space" %>

      <%= f.select :space_id,
        options_from_collection_for_select(@spaces, :id, :name, @document_import.space_id),
        { prompt: "Select a space..." },
        { class: "form-input" } %>
    </div>

    <div class="form-field">
      <%= f.label :file, "Document File" %>

      <%= f.file_field :file,
        accept: ".md,.txt,.docx,.doc,.doct",
        class: "form-input" %>

      <i class="form-hint">
        Supported formats: Markdown (.md), Plain text (.txt), Word documents (.docx, .doc, .doct)
      </i>
    </div>

    <div class="form-footer">
      <%= link_to "Cancel", imports_path, class: "secondary-button" %>
      <%= f.submit "Import Document", class: "form-submit" %>
    </div>
  <% end %>
</section>
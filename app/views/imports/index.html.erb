<% content_for :focused_header do %>
  Document Imports
<% end %>

<% content_for :focused_header_buttons do %>
  <%= link_to "Import New Document", new_import_path, class: "primary-button" %>
<% end %>

<% content_for :focused_content do %>
  <% if @document_imports.any? %>
    <div class="imports-list">
      <% @document_imports.each do |import| %>
        <div class="import-item border rounded-lg p-4 mb-4">
          <div class="flex justify-between items-start">
            <div class="import-details">
              <h3 class="font-semibold">
                <%= link_to import.filename, import_path(import), class: "link" %>
              </h3>
              <div class="text-sm text-gray-600 mt-1">
                <span>Space: <%= import.space.name %></span> • 
                <span>Imported by: <%= import.organization_user.display_name %></span> • 
                <span><%= import.created_at.strftime("%B %d, %Y") %></span>
              </div>
            </div>
            <div class="import-status">
              <% if import.successful? %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-green-100 text-green-800">
                  ✓ Completed
                </span>
              <% else %>
                <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
                  ⏳ Processing
                </span>
              <% end %>
            </div>
          </div>
          
          <% if import.successful? %>
            <div class="mt-3">
              <%= link_to "View Document", document_path(import.document), class: "btn btn-sm btn-secondary" %>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="empty-state text-center py-12">
      <h3 class="text-lg font-medium text-gray-900 mb-2">No imports yet</h3>
      <p class="text-gray-500 mb-4">Start by importing your first document.</p>
      <%= link_to "Import Document", new_import_path, class: "btn btn-primary" %>
    </div>
  <% end %>
<% end %>

<%= render "focused_section" %>
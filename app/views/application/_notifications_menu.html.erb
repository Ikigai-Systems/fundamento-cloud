<% if current_organization.present? %>
  <%= turbo_frame_tag :notifications,
    src: notifications_path,
    data: { turbo: false },
    loading: "lazy" do %>
    <%= link_to root_path(:anchor => "mentions"),
      title: "Notifications",
      class: "ml-2 document-toolbar-button relative inline-flex items-center p-2 text-sm font-medium text-center rounded-lg focus:ring-2 focus:ring-inset focus:outline-none focus:ring-black" do %>
      <span class="icon-[heroicons--bell] size-5"></span>
      <span class="sr-only">Notifications</span>
    <% end %>
  <% end %>
<% end %>
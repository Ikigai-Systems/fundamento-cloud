<div
  data-controller="dropdown"
  data-action="click@window->dropdown#hide touchstart@window->dropdown#hide keydown.up->dropdown#previousItem keydown.down->dropdown#nextItem keydown.esc->dropdown#hide"
  class="relative inline-block text-left"
>
  <button
    id="spaces-dropdown"
    data-action="dropdown#toggle:stop"
    class="inline-flex w-full justify-center gap-x-1.5 rounded-md bg-white px-3 py-2 text-sm font-semibold text-gray-900 shadow-sm ring-1 ring-inset ring-gray-300 hover:bg-gray-50 dark:!bg-gray-800 dark:ring-gray-500 dark:text-gray-400 dark:hover:text-white dark:hover:!bg-gray-700"
    aria-expanded="true"
    aria-haspopup="true">
    <span>
      <%= render ObjectIcon.new(type: Space) %>
      Spaces
    </span>

    <svg class="-mr-1 h-5 w-5 text-gray-400" viewBox="0 0 20 20" fill="currentColor" aria-hidden="true">
      <path fill-rule="evenodd" d="M5.23 7.21a.75.75 0 011.06.02L10 11.168l3.71-3.938a.75.75 0 111.08 1.04l-4.25 4.5a.75.75 0 01-1.08 0l-4.25-4.5a.75.75 0 01.02-1.06z" clip-rule="evenodd" />
    </svg>
  </button>

  <div
    data-dropdown-target="menu"
    class="hidden absolute top-5 left-0 z-10 mt-5 flex w-screen max-w-max"
    role="menu"
    aria-orientation="vertical"
    aria-labelledby="spaces-dropdown"
    tabindex="-1"
  >
    <div class="dropdown-container w-56">
      <% if current_organization.present? %>
        <% policy_scope(current_organization.spaces).order(:name).filter(&:persisted?).each do |space| %>
          <%= link_to space_path(space),
            data: {"dropdown-target" => "menuItem"},
            class: "truncate",
            role: "menuitem",
            tabindex: "-1" do
          %>
            <%= render ObjectIcon.new(object: space) %>
            <%= space.try(:title_emojiless) || space.try(:title) %>
          <% end %>
        <% end %>
      <% end %>

      <% if policy(Space).create? %>
        <hr class="border-t">

        <%= link_to "Create space", new_space_path, data: {"dropdown-target" => "menuItem"}, role: "menuitem", tabindex: "-1" %>
      <% end %>
    </div>
  </div>
</div>

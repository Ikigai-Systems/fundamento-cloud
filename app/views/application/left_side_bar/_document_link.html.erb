<% document = @documents.find { |document| document.id == document_id } %>
<% if document.present? %>
  <%= link_to edit_space_document_path(@space, document) do %>
    <% if document.archived %>
      <div data-visibility-target="hideable" hidden class="text-slate-400">
    <% else %>
      <div class="text-slate-800">
    <% end %>

    <% if @document == document %>
      <div data-document-id="<%= document.id %>" class="text-left mx-2 p-2 bg-blue-100 hover:bg-blue-200 active:bg-blue-300">
    <% else %>
      <div data-document-id="<%= document.id %>" class="text-left mx-2 p-2 hover:bg-gray-100 active:bg-gray-200">
    <% end %>
<!--      <div style="padding-left: <%#=level * 16%>px">-->
        <%= document.title.presence || "Untitled" %>
<!--      </div>-->
    </div>

    </div>
  <% end %>
<% end %>

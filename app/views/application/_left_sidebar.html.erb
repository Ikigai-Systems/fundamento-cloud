<%
  if defined?(@document)
    object = @document
  elsif defined?(@table)
    object = @table
  end
%>

<aside id="left-side-bar" class="sidebar" data-turbo-keep-scroll>
  <%= turbo_frame_tag "left_sidebar_content", data: { turbo: false }, src: sidebar_space_path(@space, object: { type: object&.class, id: object&.id }) do %>
    <%= render template: "application/components/loading" %>
  <% end %>
</aside>

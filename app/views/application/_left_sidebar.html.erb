<%
  if defined?(@document)
    object = @document
  elsif defined?(@table)
    object = @table
  end
%>

<aside id="space-sidebar" class="space-sidebar sidebar group/collapser <%= cookies["ikigai_userPreferences_leftSideBarExpanded"] == "false" ? "collapsed " : "" %>"
       data-controller="cookie-controlled-toggle"
       data-cookie-controlled-toggle-cookie-key-value="ikigai_userPreferences_leftSideBarExpanded"
       data-cookie-controlled-toggle-target="toggleable" data-toggle-class="collapsed"
       data-cookie-controlled-toggle-open-value="<%= !(cookies["ikigai_userPreferences_leftSideBarExpanded"] == "false") %>"
       data-turbo-keep-scroll>
  <div class="relative z-10">
    <div class="sidebar-collapse-trigger -right-3.5 group-[.collapsed]/collapser:right-1"
         data-controller="hotkey popover"
         data-hotkey="["
         data-action="click->cookie-controlled-toggle#toggle touch->cookie-controlled-toggle#toggle mouseenter->popover#show mouseleave->popover#hide"
    >
      <span class="icon-[heroicons--chevron-left-16-solid] size-4 ml-1.5 mt-[4px] block group-[.collapsed]/collapser:hidden"></span>
      <span class="icon-[heroicons--chevron-right-16-solid] size-4 ml-1.5 mt-[4px] hidden group-[.collapsed]/collapser:block"></span>

      <template data-popover-target="content">
        <div data-popover-target="card" class="popover-tooltip-card w-24 flex flex-row items-center justify-center left-8 -top-1">
          <p class="block group-[.collapsed]/collapser:hidden">Collapse <code>[</code></p>
          <p class="hidden group-[.collapsed]/collapser:block">Expand <code>[</code></p>
        </div>
      </template>
    </div>
  </div>

  <div class="sidebar-internal">
    <div class="m-5 rounded-xl drop-shadow-lg sidebar-colors grow">
      <%= turbo_frame_tag "space_sidebar", data: { turbo: false }, src: sidebar_space_path(@space, object: { type: object&.class, id: object&.id }) do %>
        <%= render Object::SidebarLoadingComponent.new %>
      <% end %>
    </div>
  </div>
</aside>

<aside class="bg-white border-r overflow-auto">
  <div class="p-4 flex flex-col h-full" data-controller="visibility">
    <div class="flex justify-between items-center text-center">
      <div class="mx-4 py-2 font-bold text-xs text-slate-600 uppercase">Documents</div>
      <div class="hover:bg-gray-100 active:bg-gray-200 size-6 mr-2" title="Add document">
        <%= link_to new_space_document_path(@space) do %>
          <span class="size-5 mt-0.5 text-slate-800 icon-[heroicons--plus]"></span>
        <% end %>
      </div>
    </div>
    <div>
      <div class="text-slate-400 mx-2 p-2 hidden only:block">No documents in this space</div>
      <%= render partial: "application/left_side_bar/hierarchy_node", locals: { node: @space.hierarchy, level: 0 } %>
    </div>
    <div class="mt-auto self-end">
      Archived:
      <button class="btn" data-action="visibility#show">Show</button>
      <button class="btn" data-action="visibility#hide">Hide</button>
    </div>
  </div>
</aside>

<% object = favorite.object %>

<div id="<%= dom_id(favorite) %>" class="flex items-center justify-start w-full">
  <div class="p-2 flex-grow">
    <div class="text-base font-semibold">
      <%= link_to object.try(:title) || object.try(:name), polymorphic_path([object]), data: { turbo: false } %>
    </div>
    <div class="font-normal text-gray-500">Last updated <%= time_ago_in_words object.updated_at %></div>
  </div>
  <%= button_to favorite_path(favorite.npi),
    method: :delete,
    class: "secondary-button" do
  %>
    <i class="fa-regular fa-trash-can"></i>
  <% end %>
</div>
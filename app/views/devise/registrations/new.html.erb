<% if !Flipper.enabled?(:standalone) %>
  <div class="w-full grid grid-cols-1 md:grid-cols-10 md:gap-8 md:px-8">
    <div class="max-w-screen-md md:col-start-2 md:col-span-5">
<% else %>
  <div class="w-full flex flex-col items-center">
    <div class="max-w-screen-md w-full">
<% end %>

<section class="form-section w-full">
  <% if !Flipper.enabled?(:standalone) %>
    <h1 class="mt-0 max-w-75">
      <span class="text-4xl font-semibold block mt-3">Fundamento</span>
      <span class="text-lg font-normal">Sign up for a free account</span>
    </h1>
  <% else %>
    <h1 class="mt-0 max-w-75">
      <span class="text-3xl">Create an account</span>
    </h1>
  <% end %>

  <%= form_for(resource, as: resource_name, url: registration_path(resource_name),
    html: { class: "default-form" }) do |f|
  %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="form-field">
      <%= f.label :email %>
      <%= f.email_field :email, class: "form-input" %>
    </div>

    <% if Flipper.enabled?(:standalone) %>
      <% if resource.respond_to?(:first_name) %>
        <div class="form-field">
          <%= f.label :first_name %>
          <%= f.text_field :first_name, class: "form-input" %>
        </div>
      <% end %>

      <% if resource.respond_to?(:last_name) %>
        <div class="form-field">
          <%= f.label :last_name %>
          <%= f.text_field :last_name, class: "form-input" %>
        </div>
      <% end %>

      <div class="form-field">
        <%= f.label :password %>
        <%= f.password_field :password, class: "form-input" %>
      </div>

      <div class="form-field">
        <%= f.label :password_confirmation %>
        <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input" %>
      </div>
    <% end %>

    <% if Flipper.enabled?(:recaptcha) %>
      <%= recaptcha_tags(noscript: false) %>
    <% end %>

    <div class="form-footer">
      <%= f.submit "Create an account", class: "form-submit w-full" %>
    </div>

    <% if Flipper.enabled?(:google_auth) %>
      <%= render 'spacer' %>

      <%= link_to sign_up_with_google_path,
        data: { turbo: false },
        class: "flex flex-row items-center justify-center mt-8 w-full secondary-button h-10 text-center gap-2" do %>
        <div class="size-5">
          <svg version="1.1" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 48 48" xmlns:xlink="http://www.w3.org/1999/xlink" style="display: block;">
            <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"></path>
            <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"></path>
            <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"></path>
            <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"></path>
            <path fill="none" d="M0 0h48v48H0z"></path>
          </svg>
        </div>
        <div>
          Sign up with Google
        </div>
      <% end %>
    <% end %>
  <% end %>

  <%= render 'spacer' %>

  <div class="md:my-4 mb-4">
    Already have an account? <%= link_to "Sign in ->", new_session_path(resource_name), class: "link-button" %>
  </div>
</section>

</div>

<% if !Flipper.enabled?(:standalone) %>
  <div class="md:col-start-7 md:col-span-3">
    <hr class="mt-4 md:hidden">
    <section class="form-section w-full p-0">
      <a href="https://fundamento.it/self-hosted-trial" class="py-8 px-4 font-semibold md:shadow md:mt-8 text-sm rounded flex flex-row items-center gap-2">
        <span class="min-w-6 size-6 icon-[heroicons--server-stack]"></span>
        Want to host Fundamento on your own server? Start a self-hosted trial
        <span class="ml-auto min-w-6 size-6 icon-[heroicons--arrow-right]"></span>
      </a>
    </section>
  </div>
<% end %>
</div>

<section class="form-section">
  <h2 class="form-header">Resend unlock instructions</h2>

  <%= form_for(resource, as: resource_name, url: unlock_path(resource_name), html: { class: "default-form" }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="form-field">
      <%= f.label :email %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-input" %>
    </div>

    <div class="form-footer">
      <%= f.submit "Resend unlock instructions", class: "form-submit" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</section>
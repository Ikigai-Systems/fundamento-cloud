<div style="display: flex; flex-direction: column; align-items: center; max-width: 720px; margin: auto;">
  <div>
    <!--replace with real Fundamento icon later:-->
    <svg xmlns="http://www.w3.org/2000/svg" fill="currentColor" stroke="currentColor" viewBox="0 0 576 512" style="height: 4rem; width: 4rem;"><path d="m290.8 48.6 78.4 29.7-81.2 31.2-81.2-31.2 78.4-29.7c1.8-.7 3.8-.7 5.7 0zM136 92.5v112.2c-1.3.4-2.6.8-3.9 1.3l-96 36.4C14.4 250.6 0 271.5 0 294.7v119.2c0 22.2 13.1 42.3 33.5 51.3l96 42.2c14.4 6.3 30.7 6.3 45.1 0L288 457.5l113.5 49.9c14.4 6.3 30.7 6.3 45.1 0l96-42.2c20.3-8.9 33.5-29.1 33.5-51.3V294.8c0-23.3-14.4-44.1-36.1-52.4L444 206c-1.3-.5-2.6-.9-3.9-1.3V92.5c0-23.3-14.4-44.1-36.1-52.4L308 3.7c-12.8-4.8-26.9-4.8-39.7 0l-96 36.4C150.4 48.4 136 69.3 136 92.5zm256 118.1-82.4 31.2v-89.2L392 121zm-237.2 40.3 78.4 29.7-81.2 31.1-81.2-31.1 78.4-29.7c1.8-.7 3.8-.7 5.7 0zm18.8 204.4V354.8l82.4-31.6v95.9zm247.6-204.4c1.8-.7 3.8-.7 5.7 0l78.4 29.7-81.3 31.1-81.2-31.1zm102 170.3-77.6 34.1V354.8l82.4-31.6v90.7c0 3.2-1.9 6-4.8 7.3z"></path></svg>
  </div>
  <div style="font-size: 1.5rem; line-height: 2rem;">
    <%= @resource.invited_by.display_name %> invited you to <strong><%= @resource.organization.name %></strong>, an organization on <a href="https://fundamento.it">Fundamento</a>.
  </div>
  <div style="margin-top: 2rem; display: flex; flex-direction: column; align-items: center; max-width: 480px; height: 200px; border-style: solid; border-radius: 1rem; border-width: 1px; border-color: #ccc; padding: 1rem;">
    <div style="display: flex; flex-direction: row; align-items: center; justify-content: center">
      <div style="min-width: 2rem; min-height: 2rem; background-color: rgb(59 130 246); border-radius: 9999px; display:flex; align-items: center; justify-content: center; color:white; font-weight: 700;">
        <%= @resource.invited_by.initials %>
      </div>
      <div style="padding: 1rem;">
        I've just added you to a Fundamento organization, where we can collaborate on our documents and our data. Let's get started!
      </div>
    </div>

    <%= link_to t("devise.mailer.invitation_instructions.accept"), accept_invitation_url(@resource, invitation_token: @token), style: 'margin-top: 2rem; font-weight: 600; text-decoration: none; background-color: rgb(251 146 60); color: rgb(15 23 42); padding: 0.5rem 1.5rem; border-radius: .375rem;'%>
  </div>
  <div style="color: #aaa; font-size: 0.8rem; ">
    <% if @resource.invitation_due_at %>
      <p><%= t("devise.mailer.invitation_instructions.accept_until", due_date: l(@resource.invitation_due_at, format: :'devise.mailer.invitation_instructions.accept_until_format')) %></p>
    <% end %>

    <p><%= t("devise.mailer.invitation_instructions.ignore") %></p>
  </div>
  <!--  here we should later include some kind of footer, maybe who we are, maybe icons to our social accounts-->
</div>

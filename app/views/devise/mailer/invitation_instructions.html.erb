<table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" align="center">
  <tbody>
  <tr>
    <td style="font-size:0;line-height:0;mso-line-height-rule:exactly;background-color:#F9F9F9;background-image:none;background-repeat:repeat;background-size:auto;background-position:center top;" valign="top" align="center">
      <table role="presentation" width="100%" cellpadding="0" cellspacing="0" border="0" align="center" id="innerTable">
        <tbody>
        <tr>
          <td>
            <div style="mso-line-height-rule:exactly;mso-line-height-alt:70px;line-height:70px;font-size:1px;display:block;">&nbsp;&nbsp;</div>
          </td>
        </tr>
        <tr>
          <td align="center">
            <table role="presentation" cellpadding="0" cellspacing="0" style="Margin-left:auto;Margin-right:auto;">
              <tbody>
              <tr>
                <td style="background-color:#FFFFFF;border:1px solid #CECECE;overflow:hidden;width:480px;border-radius:20px 20px 20px 20px;">
                  <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="width:100%;">
                    <tbody>
                    <tr>
                      <td style="padding:50px 40px 40px 40px;">
                        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="width:100% !important;">
                          <tbody>
                          <tr>
                            <td align="center">
                              <table role="presentation" cellpadding="0" cellspacing="0" style="Margin-left:auto;Margin-right:auto;">
                                <tbody>
                                <tr>
                                  <td style="width:60px;">
                                    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="width:100%;">
                                      <tbody>
                                      <tr>
                                        <td>
                                          <img alt="Fundamento Logo" loading="lazy" height="64" style="color:transparent" src="<%= attachments["logo.png"].url %>">
                                        </td>
                                      </tr>
                                      </tbody>
                                    </table>
                                  </td>
                                </tr>
                                </tbody>
                              </table>
                            </td>
                          </tr>
                          <tr>
                            <td>
                              <div style="mso-line-height-rule:exactly;mso-line-height-alt:40px;line-height:40px;font-size:1px;display:block;">&nbsp;&nbsp;</div>
                            </td>
                          </tr>
                          <tr>
                            <td align="center">
                              <table role="presentation" cellpadding="0" cellspacing="0" style="Margin-left:auto;Margin-right:auto;">
                                <tbody>
                                <tr>
                                  <td style="width:398px;">
                                    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="width:100%;">
                                      <tbody>
                                      <tr>
                                        <td>
                                          <h1 style="margin:0;Margin:0;font-family:Inter,BlinkMacSystemFont,Segoe UI,Helvetica Neue,Arial,sans-serif;line-height:28px;font-weight:500;font-style:normal;font-size:24px;text-decoration:none;text-transform:none;letter-spacing:-1.2px;direction:ltr;color:#111111;text-align:center;mso-line-height-rule:exactly;mso-text-raise:1px;">
                                            <%= @resource.invited_by.display_name %> invited you to <strong><%= @resource.organization.name %></strong>, an organization on Fundamento.</h1>
                                        </td>
                                      </tr>
                                      </tbody>
                                    </table>
                                  </td>
                                </tr>
                                </tbody>
                              </table>
                            </td>
                          </tr>
                          <tr>
                            <td>
                              <div style="mso-line-height-rule:exactly;mso-line-height-alt:17px;line-height:17px;font-size:1px;display:block;">&nbsp;&nbsp;</div>
                            </td>
                          </tr>
                          <tr>
                            <td align="center">
                              <table role="presentation" cellpadding="0" cellspacing="0" style="Margin-left:auto;Margin-right:auto;">
                                <tbody>
                                <tr>
                                  <td style="width:388px;">
                                    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="width:100%;">
                                      <tbody>
                                      <tr>
                                        <td style="width:32px;">
                                          <p style="height:32px;width:32px;background-color:#3b82f6;color:white;border-radius:100px;margin:0;Margin:0;font-family:Inter,BlinkMacSystemFont,Segoe UI,Helvetica Neue,Arial,sans-serif;line-height:32px;font-weight:700;font-style:normal;font-size:15px;text-decoration:none;text-transform:none;letter-spacing:-0.6px;direction:ltr;text-align:center;mso-line-height-rule:exactly;mso-text-raise:2px;">
                                            <%= @resource.invited_by.initials %>
                                          </p>
                                        </td>
                                        <td>
                                          <p style="margin:0;Margin:0;margin-left: 16px;font-family:Inter,BlinkMacSystemFont,Segoe UI,Helvetica Neue,Arial,sans-serif;line-height:22px;font-weight:500;font-style:normal;font-size:15px;text-decoration:none;text-transform:none;letter-spacing:-0.6px;direction:ltr;color:#424040;text-align:left;mso-line-height-rule:exactly;mso-text-raise:2px;">
                                            I've just added you to a Fundamento organization, where we can collaborate on our documents and our data. Let's get started!
                                          </p>
                                        </td>
                                      </tr>
                                      </tbody>
                                    </table>
                                  </td>
                                </tr>
                                </tbody>
                              </table>
                            </td>
                          </tr>
                          <tr>
                            <td>
                              <div style="mso-line-height-rule:exactly;mso-line-height-alt:40px;line-height:40px;font-size:1px;display:block;">&nbsp;&nbsp;</div>
                            </td>
                          </tr>
                          <tr>
                            <td align="center">
                              <table role="presentation" cellpadding="0" cellspacing="0" style="Margin-left:auto;Margin-right:auto;">
                                <tbody>
                                <tr>
                                  <td style="background-color:#fb923c;overflow:hidden;width:154px;border-radius:8px 8px 8px 8px;">
                                    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="width:100%;">
                                      <tbody>
                                      <tr>
                                        <td style="text-align:center;line-height:40px;mso-line-height-rule:exactly;mso-text-raise:8px;">
                                          <%= link_to "Accept invite", accept_invitation_url(@resource, invitation_token: @token), style: 'display:block;margin:0;Margin:0;font-family:Inter,BlinkMacSystemFont,Segoe UI,Helvetica Neue,Arial,sans-serif;line-height:40px;font-weight:700;font-style:normal;font-size:15px;text-decoration:none;letter-spacing:-0.5px;direction:ltr;color:#0f172a;text-align:center;mso-line-height-rule:exactly;mso-text-raise:8px;' %>
                                        </td>
                                      </tr>
                                      </tbody>
                                    </table>
                                  </td>
                                </tr>
                                </tbody>
                              </table>
                            </td>
                          </tr>
                          <tr>
                            <td>
                              <div style="mso-line-height-rule:exactly;mso-line-height-alt:40px;line-height:40px;font-size:1px;display:block;">&nbsp;&nbsp;</div>
                            </td>
                          </tr>
                          <tr>
                            <td align="center">
                              <table role="presentation" cellpadding="0" cellspacing="0" style="Margin-left:auto;Margin-right:auto;">
                                <tbody>
                                <tr>
                                  <td style="width:398px;">
                                    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="width:100%;">
                                      <tbody>
                                      <tr>
                                        <td>
                                          <% if @resource.invitation_due_at %>
                                          <p style="margin:0;Margin:0;font-family:Inter,BlinkMacSystemFont,Segoe UI,Helvetica Neue,Arial,sans-serif;line-height:20px;font-weight:500;font-style:normal;font-size:13px;text-decoration:none;text-transform:none;letter-spacing:-0.6px;direction:ltr;color:#aaa;text-align:left;mso-line-height-rule:exactly;mso-text-raise:2px;">
                                            <%= t("devise.mailer.invitation_instructions.accept_until", due_date: l(@resource.invitation_due_at, format: :'devise.mailer.invitation_instructions.accept_until_format')) %>
                                          </p>
                                          <% end %>
                                          <p style="margin:0;Margin:0;margin-top: 12px; font-family:Inter,BlinkMacSystemFont,Segoe UI,Helvetica Neue,Arial,sans-serif;line-height:20px;font-weight:500;font-style:normal;font-size:13px;text-decoration:none;text-transform:none;letter-spacing:-0.6px;direction:ltr;color:#aaa;text-align:left;mso-line-height-rule:exactly;mso-text-raise:2px;">
                                            <%= t("devise.mailer.invitation_instructions.ignore") %>
                                          </p>
                                        </td>
                                      </tr>
                                      </tbody>
                                    </table>
                                  </td>
                                </tr>
                                </tbody>
                              </table>
                            </td>
                          </tr>
                          <tr>
                            <td>
                              <div style="mso-line-height-rule:exactly;mso-line-height-alt:30px;line-height:30px;font-size:1px;display:block;">&nbsp;&nbsp;</div>
                            </td>
                          </tr>
                          <tr>
                            <td align="center">
                              <table role="presentation" cellpadding="0" cellspacing="0" style="Margin-left:auto;Margin-right:auto;">
                                <tbody>
                                <tr>
                                  <td style="background-color:#F2EFF3;overflow:hidden;width:398px;border-radius:8px 8px 8px 8px;">
                                    <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="width:100%;">
                                      <tbody>
                                      <tr>
                                        <td style="padding:20px 30px 20px 30px;">
                                          <p style="margin:0;Margin:0;font-family:Albert Sans,BlinkMacSystemFont,Segoe UI,Helvetica Neue,Arial,sans-serif;line-height:18px;font-weight:500;font-style:normal;font-size:12px;text-transform:none;direction:ltr;color:#84828E;text-align:center;mso-line-height-rule:exactly;mso-text-raise:2px;">
                                            P.S. Need help getting started? Check out our <a target="_blank" style="color: #0e87bc; text-decoration: underline" href="https://docs.fundamento.it">help documentation</a>.
                                          </p></td>
                                      </tr>
                                      </tbody>
                                    </table>
                                  </td>
                                </tr>
                                </tbody>
                              </table>
                            </td>
                          </tr>
                          </tbody>
                        </table>
                      </td>
                    </tr>
                    </tbody>
                  </table>
                </td>
              </tr>
              </tbody>
            </table>
          </td>
        </tr>
        <tr>
          <table role="presentation" cellpadding="0" cellspacing="0" style="Margin-left:auto;Margin-right:auto;">
            <tbody>
            <tr>
              <td style="width:398px;">
                <table role="presentation" cellpadding="0" cellspacing="0" width="100%" style="width:100%;">
                  <tbody>
                  <tr>
                    <td>
                      <p style="margin:0;Margin:0;margin-top: 40px; margin-bottom: 40px; font-family:Inter,BlinkMacSystemFont,Segoe UI,Helvetica Neue,Arial,sans-serif;line-height:20px;font-weight:500;font-style:normal;font-size:13px;text-decoration:none;text-transform:none;letter-spacing:-0.6px;direction:ltr;color:#aaa;text-align:center;mso-line-height-rule:exactly;mso-text-raise:2px;">
                        © 2025 <a style="color:#aaa" href="https://fundamento.it">Fundamento</a>. All Rights Reserved.
                      </p>
                    </td>
                  </tr>
                  </tbody>
                </table>
              </td>
            </tr>
            </tbody>
          </table>
        </tr>
        <tr>
          <td>
            <div style="mso-line-height-rule:exactly;mso-line-height-alt:70px;line-height:70px;font-size:1px;display:block;">&nbsp;&nbsp;</div>
          </td>
        </tr>
        </tbody>
      </table>
    </td>
  </tr>
  </tbody>
</table>
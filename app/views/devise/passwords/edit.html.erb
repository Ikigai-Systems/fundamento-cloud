<section class="form-section">
  <h2 class="form-header">Change your password</h2>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name),
    html: { method: :put, class: "default-form" }) do |f|
  %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <%= f.hidden_field :reset_password_token %>

    <div class="form-field">
      <%= f.label :password, "New password" %>
      <% if @minimum_password_length %>
        <i class="form-hint">(<%= @minimum_password_length %> characters minimum)</i>
      <% end %>
      <%= f.password_field :password, autofocus: true, autocomplete: "new-password", class: "form-input" %>
    </div>

    <div class="form-field">
      <%= f.label :password_confirmation, "Confirm new password" %>
      <%= f.password_field :password_confirmation, autocomplete: "new-password", class: "form-input" %>
    </div>

    <div class="form-footer">
      <%= f.submit "Change my password", class: "form-submit" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</section>
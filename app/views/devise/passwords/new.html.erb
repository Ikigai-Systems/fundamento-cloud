<section class="form-section">
  <h2 class="text-lg font-semibold text-gray-700 capitalize dark:text-white">Forgot your password?</h2>

  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <div class="my-5">
      <%= f.label :email %><br />
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "block shadow rounded-md border border-gray-200 outline-none px-3 py-2 mt-2 w-full" %>
    </div>

    <div class="flex justify-end mt-6">
      <%= f.submit "Send me reset password instructions", class: "form-submit" %>
    </div>
  <% end %>

  <%= render "devise/shared/links" %>
</section>
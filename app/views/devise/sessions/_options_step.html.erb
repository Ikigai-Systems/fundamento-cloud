<!-- Authentication options (for users with passwords) -->
<section class="form-section">
  <h2 class="form-header">Welcome back</h2>

  <p class="form-legend">
    Signing in as <strong><%= resource.email %></strong>
  </p>

  <!-- Password authentication option -->
  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "default-form", data: { turbo: false } }) do |f| %>
    <%= f.hidden_field :email, value: resource.email %>
    <%= f.hidden_field :authentication_method, value: "password" %>

    <div class="form-field">
      <%= f.label :password %>
      <%= f.password_field :password, autocomplete: "current-password", class: "form-input", autofocus: true %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="form-field flex gap-2 items-center">
        <%= f.check_box :remember_me, class: "h-4 w-4 rounded" %>
        <%= f.label :remember_me, "Remember me" %>
      </div>
    <% end %>

    <div class="form-footer">
      <%= f.submit "Sign in with password", class: "form-submit" %>
    </div>
  <% end %>

  <!-- Separator -->
  <div class="relative my-6">
    <div class="absolute inset-0 flex items-center">
      <div class="w-full border-t border-gray-300"></div>
    </div>
    <div class="relative flex justify-center text-sm">
      <span class="px-2 bg-white text-gray-500">or</span>
    </div>
  </div>

  <!-- Magic link option -->
  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { class: "default-form", data: { turbo: false } }) do |f| %>
    <%= f.hidden_field :email, value: resource.email %>
    <%= f.hidden_field :authentication_method, value: "magic_link" %>
    <%= f.hidden_field :remember_me, value: "1" %>

    <div class="form-footer">
      <%= f.submit "Email me a sign-in link", class: "secondary-button w-full" %>
    </div>
  <% end %>

  <div class="form-hint text-center mt-4">
    <%= link_to "← Use different email", new_user_session_path, class: "link-button" %>
  </div>
</section>
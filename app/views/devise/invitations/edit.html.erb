<section class="form-section">
  <h2 class="text-lg font-semibold text-gray-700 capitalize dark:text-white"><%= t "devise.invitations.edit.header" %></h2>

  <%= form_for(resource, as: resource_name, url: invitation_path(resource_name), html: { method: :put }) do |f| %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <%= f.hidden_field :invitation_token, readonly: true %>

    <% if f.object.class.require_password_on_accepting %>
      <div class="form-field">
        <%= f.label :password %><br />
        <%= f.password_field :password, class: "form-input" %>
      </div>

      <div class="form-field">
        <%= f.label :password_confirmation %><br />
        <%= f.password_field :password_confirmation, class: "form-input" %>
      </div>
    <% end %>

    <div class="flex justify-end mt-6">
      <%= f.submit t("devise.invitations.edit.submit_button"), class: "form-submit" %>
    </div>
  <% end %>

</section>
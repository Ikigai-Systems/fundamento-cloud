<div class="max-w-md mx-auto mt-12 p-8 bg-white rounded-xl shadow-sm border border-gray-200">
  <h1 class="text-xl font-semibold text-gray-900 mb-2">Authorize Access</h1>

  <p class="text-gray-600 mb-6">
    <strong class="text-gray-900"><%= @pre_auth.client.name %></strong>
    wants to access your Fundamento workspace.
  </p>

  <% if @pre_auth.scopes.count > 0 %>
    <div class="mb-6 p-4 bg-gray-50 rounded-lg">
      <p class="text-sm font-medium text-gray-700 mb-2">This will allow the app to:</p>
      <ul class="space-y-1">
        <% @pre_auth.scopes.each do |scope| %>
          <li class="text-sm text-gray-600 flex items-center gap-2">
            <span class="text-green-500">&#10003;</span>
            <%= t(scope, scope: [:doorkeeper, :scopes], default: scope.humanize) %>
          </li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="space-y-3">
    <%= form_tag oauth_authorization_path, method: :post do %>
      <%= hidden_field_tag :client_id, @pre_auth.client.uid, id: nil %>
      <%= hidden_field_tag :redirect_uri, @pre_auth.redirect_uri, id: nil %>
      <%= hidden_field_tag :state, @pre_auth.state, id: nil %>
      <%= hidden_field_tag :response_type, @pre_auth.response_type, id: nil %>
      <%= hidden_field_tag :response_mode, @pre_auth.response_mode, id: nil %>
      <%= hidden_field_tag :scope, @pre_auth.scope, id: nil %>
      <%= hidden_field_tag :code_challenge, @pre_auth.code_challenge, id: nil %>
      <%= hidden_field_tag :code_challenge_method, @pre_auth.code_challenge_method, id: nil %>
      <%= hidden_field_tag :organization_membership_id, session[:oauth_organization_membership_id], id: nil %>
      <%= submit_tag "Authorize", class: "w-full py-2 px-4 bg-blue-600 text-white rounded-lg font-medium hover:bg-blue-700 cursor-pointer" %>
    <% end %>

    <%= form_tag oauth_authorization_path, method: :delete do %>
      <%= hidden_field_tag :client_id, @pre_auth.client.uid, id: nil %>
      <%= hidden_field_tag :redirect_uri, @pre_auth.redirect_uri, id: nil %>
      <%= hidden_field_tag :state, @pre_auth.state, id: nil %>
      <%= hidden_field_tag :response_type, @pre_auth.response_type, id: nil %>
      <%= hidden_field_tag :response_mode, @pre_auth.response_mode, id: nil %>
      <%= hidden_field_tag :scope, @pre_auth.scope, id: nil %>
      <%= hidden_field_tag :code_challenge, @pre_auth.code_challenge, id: nil %>
      <%= hidden_field_tag :code_challenge_method, @pre_auth.code_challenge_method, id: nil %>
      <%= submit_tag "Deny", class: "w-full py-2 px-4 bg-white text-gray-700 rounded-lg font-medium border border-gray-300 hover:bg-gray-50 cursor-pointer" %>
    <% end %>
  </div>
</div>

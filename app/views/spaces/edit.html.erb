<section class="form-section">
  <h2 class="form-header">Edit space</h2>

  <%= form_for(@space, data: { turbo: false }) do |f| %>
    <%= render "devise/shared/error_messages", resource: @space %>

    <div class="form-field">
      <%= f.label :name %><br/>
      <%= f.text_field :name, autofocus: true, class: "form-input" %>
    </div>

    <div class="form-field">
      <%= f.label :home_document %><br/>
      <%= f.collection_select :home_document_id, @space.documents.without_archived.order(:title), :id, :title, {}, class: "form-input" %>
    </div>

    <div class="form-field">
      <%= f.label :access_mode %><br/>
      <%= f.collection_select :access_mode, Space.access_modes.to_a, :first, :first, {}, class: "form-input" %>
    </div>

    <div class="form-field">
      <%= f.label :space_owners %><br/>

      <div
        data-controller="multiselect"
        data-multiselect-search-url-value="<%= suggest_owners_space_path(@space) %>"
        data-placeholder="Search for owners...">

        <select multiple="multiple" class="multiselect__hidden" data-multiselect-target="hidden" name="form[test_ids][]" id="form_test_ids"></select>
      </div>
    </div>

    <div class="flex justify-end mt-6">
      <%= f.submit "Save", class: "form-submit" %>
    </div>
  <% end %>
</section>
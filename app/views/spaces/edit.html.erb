<section class="form-section">
  <h2 class="form-header">Edit space <%= @space.name %></h2>

  <%= form_for(@space,
    html: { class: "default-form" },
    data: { turbo: false, controller: "prevent-double-submit" }) do |f|
  %>
    <%= render "devise/shared/error_messages", resource: @space %>

    <div class="form-field">
      <%= f.label :name %>
      <%= f.text_field :name, autofocus: true, class: "form-input" %>
    </div>

    <div class="form-field">
      <%= f.label :home_document %>
      <%= f.collection_select :home_document_id, @space.documents.without_archived.order(:title), :id, :title, {}, class: "form-input" %>
    </div>

    <div class="form-field" data-controller="show-if-input-value-equals">
      <%= f.label :access_mode %>
      <%= f.collection_select :access_mode, Space.access_modes.to_a, :first, :first, {}, class: "form-input", data: { "show-if-input-value-equals_target" => "input", action: "change->show-if-input-value-equals#refresh" } %>

      <div class="form-hint">
        <div <%= @space.access_mode != 'public' ? "hidden" : "" %> data-show-if-input-value-equals-target="output" data-show-if-input-value-equals="public">
          In <b>public</b> mode every document in this space will be visible and editable to anyone within organization.
        </div>
        <div <%= @space.access_mode != 'restricted' ? "hidden" : "" %> data-show-if-input-value-equals-target="output" data-show-if-input-value-equals="restricted">
          In <b>restricted</b> mode every document in this space will be visible to anyone within organization, but editable only to space managers or organization managers.
        </div>
        <div <%= @space.access_mode != 'private' ? "hidden" : "" %> data-show-if-input-value-equals-target="output" data-show-if-input-value-equals="private">
          In <b>private</b> mode every document in this space will be visible and editable only to space managers or organization managers.
        </div>
      </div>
    </div>

    <div class="form-field">
      <%= f.label :space_managers %>

      <div
        data-controller="multiselect"
        data-multiselect-selected-value="<%= space_memberships_to_multiselect_value(@space) %>"
        data-multiselect-search-url-value="<%= suggest_owners_spaces_path %>"
        data-placeholder="Search for space managers..."
        data-no-results-message="Nothing matches">

        <%= f.select :space_memberships, [], { multiple: true }, { class: "multiselect__hidden", data: { multiselect_target: "hidden" } } %>
      </div>

      <p class="form-hint">You can pick among users and <%= link_to "teams", teams_path %>.</p>
    </div>

    <div class="form-footer">
      <%= link_to "Cancel", spaces_path, class: "secondary-button" %>
      <%= f.submit "Save", class: "form-submit" %>
    </div>
  <% end %>
</section>
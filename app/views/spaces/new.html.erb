<section class="form-section">
  <h2 class="form-header">Create space</h2>

  <%= form_for(@space, url: spaces_path, data: { turbo: false }) do |f| %>
    <%= render "devise/shared/error_messages", resource: @space %>

    <div class="form-field">
      <%= f.label :name %><br/>
      <%= f.text_field :name, autofocus: true, class: "form-input" %>
    </div>

    <div class="flex justify-end mt-6">
      <%= f.submit "Create", class: "form-submit" %>
    </div>
  <% end %>
</section>
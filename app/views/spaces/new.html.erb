<section class="form-section">
  <h2 class="form-header">Create space</h2>

  <%= form_for(@space, url: spaces_path,
    html: { class: "default-form" },
    data: { turbo: false, controller: "prevent-double-submit" }) do |f|
  %>
    <%= render "devise/shared/error_messages", resource: @space %>

    <div class="form-field">
      <%= f.label :name %>
      <%= f.text_field :name, autofocus: true, class: "form-input" %>

      <p class="form-hint">You can use emojis to add some fun! 🥳</p>
    </div>

    <div class="form-field" data-controller="show-if-input-value-equals">
      <%= f.label :access_mode %>
      <%= f.collection_select :access_mode, Space.access_modes.to_a, :first, :first, {},
        class: "form-input",
        data: { "show-if-input-value-equals_target" => "input", action: "change->show-if-input-value-equals#refresh" }
      %>

      <%= render partial: "space_access_mode_hint" %>
    </div>

    <div class="form-field">
      <%= f.label :space_managers %>

      <div
          data-controller="multiselect"
          data-multiselect-selected-value="<%= space_memberships_to_multiselect_value(@space) %>"
          data-multiselect-search-url-value="<%= suggest_owners_spaces_path %>"
          data-placeholder="Search for space managers..."
          data-no-results-message="Nothing matches">

        <%= f.select :space_memberships, [], { multiple: true }, { class: "multiselect__hidden", data: { multiselect_target: "hidden" } } %>
      </div>

      <p class="form-hint">You can pick among users and <%= link_to "teams", teams_path %>.</p>
    </div>

    <div class="form-footer">
      <%= link_to "Cancel", spaces_path, class: "secondary-button" %>
      <%= f.submit "Create", class: "form-submit" %>
    </div>
  <% end %>
</section>
<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<div class="h-full grid grid-cols-[minmax(10px,300px)_minmax(10px,_3fr)]">
  <%= render "application/left_side_bar" %>

  <article class="document">
    <div class="h-12 flex justify-end items-center p-2">

      <% if (favorite = pundit_user.organization_user.favorites.find_by(object: @table)) %>
        <%= render partial: "favorites/destroy_favorite", locals: { object: @table, favorite: favorite } %>
      <% else %>
        <%= render partial: "favorites/create_favorite", locals: { object: @table } %>
      <% end %>

      <%= button_to "Edit",
        edit_space_table_path(@space, @table),
        method: :get,
        # disabled: !policy(@table).update?,
        class: "primary-button document-toolbar-button"
      %>
    </div>

    <div class="overflow-auto h-[calc(100%-48px)]">
      <% if @table.present? %>
        <h1 class="text-3xl font-bold"><%= @table.name %></h1>
        <table>
          <thead>
            <tr>
              <% if @table.columns.present? %>
                <% @table.columns_in_order.each do |column| %>
                  <th class="border-x"><%= column.name %></th>
                <% end %>
              <% else %>
                No columns<br/>
              <% end %>
            </tr>
          </thead>
          <tbody>
            <% if @table.rows.present? %>
              <% @table.data_to_json[:rows].each do |row| %>
                <tr class="h-6">
                  <% row.each do |key, value| %>
                    <% next if key == "npi" %>
                    <td class="border"><%= value %></td>
                  <% end %>
                </tr>
              <% end %>
            <% else %>
              No rows<br/>
            <% end %>
          </tbody>
        </table>
      <% end %>
    </div>
  </article>
<!--  <aside class="bg-white overflow-auto border-l">-->
<!--    <h1 class="p-2 my-2 text-2xl text-slate-800">-->
<!--      right side bar content-->
<!--    </h1>-->
<!--  </aside>-->
</div>

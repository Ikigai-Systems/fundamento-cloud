<% if content.archived? %>
  <div data-visibility-target="hideable" <%= cookies["ikigai_userPreferences_showArchived"] == "true" ? "" : "hidden" %> class="text-slate-400 group">
<% else %>
  <div class="text-slate-800 group">
<% end %>
    <%= link_to polymorphic_path([content.space, content]), class: "section-content-link" do %>
      <div
        style="padding-left: <%=level * 16%>px"
        class="document-padding-left flex items-center w-full <%= selected ? "bg-blue-100 hover:bg-blue-200 active:bg-blue-300" : "hover:bg-gray-100 active:bg-gray-200" %>"
      >
        <div
          data-action="click->collapsible#toggle:prevent"
          class="multi-items-expander size-6 ml-1<%= !has_children ? " hidden" : "" %>"
        >
          <div data-collapsible-target="icon" class="icon-[heroicons--chevron-right-16-solid] size-4 m-1 transition-transform"></div>
        </div>

        <div class="single-item-dot pt-1 mx-2.5 -mt-[0.3rem]<%= has_children ? " hidden" : "" %>">•</div>

        <div data-document-id="<%= content.id %>" class="flex flex-grow min-w-0 gap-1 mx-0 p-2 items-center">
          <span class="truncate flex-grow min-w-0">
            <%= content.try(:title) || content.try(:name) %>
          </span>

          <% if content.try(:draft?) %>
            <span class="uppercase bg-gray-100 group-hover:bg-gray-200 group-hover:active:bg-gray-300 text-gray-800 text-xs font-bold font-medium px-2 py-0 h-4 rounded dark:bg-gray-700 dark:text-gray-300">Draft</span>
          <% end %>
        </div>
      </div>
    <% end %>

    <%= link_to polymorphic_path([:edit, content.space, content]),
      class: "absolute right-1 top-1 rounded-md size-7 p-1 #{ selected ? "group-hover:bg-blue-300 active:bg-blue-400" : "group-hover:bg-gray-200 active:bg-gray-300"}" do %>
      <div class="group-hover:opacity-30 opacity-0 transition-opacity duration-300 bg-gray-950 size-5 icon-[heroicons--pencil]"></div>
    <% end %>
</div>
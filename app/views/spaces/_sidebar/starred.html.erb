<%= turbo_frame_tag :starred_sidebar_tab do %>
  <%= turbo_stream_from [pundit_user.organization_membership, @space, :favorites] %>

  <div id="space_starred_list">
    <% @favorites.each do |favorite| %>
      <%= render partial: "spaces/_sidebar/starred_item", locals: { favorite: favorite } %>
    <% end %>
  </div>

  <% if @favorites.empty? %>
    <div class="flex flex-col items-center justify-center p-6 text-center gap-3">
      <i class="fa-regular fa-star text-3xl text-gray-400 dark:text-gray-500"></i>
      <div>
        <h3 class="text-gray-600 dark:text-gray-300 font-semibold">No starred items</h3>
        <p class="text-gray-500 dark:text-gray-400 text-sm mt-1">Star documents or tables in this space to find them here quickly.</p>
      </div>
    </div>
  <% end %>
<% end %>

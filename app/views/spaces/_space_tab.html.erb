<div id="<%= dom_id(space) %>" class="flex items-center justify-start w-full">
  <div class="p-2 flex-grow">
    <div class="text-base font-semibold">
      <%= link_to space_path(space) do %>
        <%= render ObjectIcon.new(object: space) %>
        <%= space.try(:title_emojiless) || space.try(:title) %>
      <% end %>
    </div>
    <div class="font-normal text-gray-500 dark:text-gray-400">Last updated <%= time_ago_in_words space.updated_at %></div>
  </div>
</div>
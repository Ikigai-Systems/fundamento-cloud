<div class="h-[calc(100vh-56px)] grid grid-cols-[minmax(10px,300px)_minmax(10px,_3fr)]">

  <aside class="bg-white border-r overflow-auto">
    <div class="p-4 flex flex-col">
      <div class="mx-4 pb-4 font-bold">Documents</div>
      <% @space.hierarchy&.map do |documentId| %>
        <% document = @documents.find { |document| document.id == documentId } %>
        <% if document.present? %>
          <div class="text-left m-x-2 p-2">
            <%= document.id %> &nbsp;
            <%= document.title.presence || "Untitled" %>
          </div>
<!--         duplicated for testing layout only:-->
          <div class="text-left m-x-2 p-2">
            <%= document.id %> &nbsp;
            <%= document.title.presence || "Untitled" %>
          </div>
          <div class="text-left m-x-2 p-2">
            <%= document.id %> &nbsp;
            <%= document.title.presence || "Untitled" %>
          </div>
          <div class="text-left m-x-2 p-2">
            <%= document.id %> &nbsp;
            <%= document.title.presence || "Untitled" %>
          </div>
        <% end %>
      <% end %>
    </div>
  </aside>
  <article>
    Test<br>
    Main Article
  </article>
</div>

<%= turbo_frame_tag "space_sidebar" do %>
  <div class="flex flex-col h-full overflow-hidden">
    <div class="flex flex-col px-3 border-b">
      <div class="mt-2">
        <%= link_to root_path, class: "flex items-center py-2" do %>
          <%= image_tag "fundamento-text-black.svg", class: "h-5 w-auto dark:hidden" %>
          <%= image_tag "fundamento-text-white.svg", class: "h-5 w-auto hidden dark:!block" %>
        <% end %>
      </div>

      <% if user_signed_in? && current_organization.present? %>
        <div class="mt-2 pb-3 w-full">
          <%= render "spaces/_sidebar/spaces_menu" %>
        </div>
      <% end %>
    </div>

    <div
      class="flex flex-col flex-1 min-h-0"
      data-controller="tabs"
      data-tabs-active-tab-class="active-tab"
    >
      <div class="shrink-0 border-b">
        <nav data-tabs-target="list" aria-label="Space sidebar tabs">
          <button id="hierarchy" data-action="click->tabs#change" data-tabs-target="tab"
                  class="flex flex-row items-center gap-1">
            <i class="fa-regular fa-sitemap"></i>
            Hierarchy
          </button>

          <button id="starred" data-action="click->tabs#change" data-tabs-target="tab"
                  class="flex flex-row items-center gap-1">
            <i class="fa-regular fa-star"></i>
            Starred
          </button>
        </nav>
      </div>

      <div class="flex-1 min-h-0 overflow-hidden">
        <%# Hierarchy panel: no loading: lazy so it fetches immediately (first tab) %>
        <div data-tabs-target="panel" class="hidden h-full">
          <%= turbo_frame_tag "hierarchy_sidebar_tab",
              src: sidebar_space_path(@space, tab: :hierarchy, object: params[:object]&.to_unsafe_h),
              data: { turbo: false } do %>
            <%= render Object::SidebarLoadingComponent.new %>
          <% end %>
        </div>

        <%# Starred panel: lazy — only fetches when user clicks the tab %>
        <div data-tabs-target="panel" class="hidden h-full">
          <%= turbo_frame_tag "starred_sidebar_tab",
              loading: "lazy",
              src: sidebar_space_path(@space, tab: :starred),
              data: { turbo: false } do %>
            <%= render Object::SidebarLoadingComponent.new %>
          <% end %>
        </div>
      </div>
    </div>
  </div>
<% end %>

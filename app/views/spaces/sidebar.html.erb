<%= turbo_frame_tag "left_sidebar_content", data: { turbo_action: "advance" } do %>
  <div class="px-4 pb-0 flex flex-col h-full">
    <%= render partial: "spaces/_sidebar/space_bar" %>

    <div class="flex flex-col h-full" data-controller="visibility" data-action="toggle-button:change->visibility#onChange">
      <div class="section-header-container">
        <div class="section-header-title">
          <i class="fa-regular fa-file-lines"></i>
          Documents
        </div>

        <%= button_to space_documents_path(@space),
          method: :post,
          params: { "document": { title: "" } },
          disabled: !policy(@space).update? || true,
          form_class: "flex items-center",
          class: "secondary-button" do
        %>
          <i class="fa-regular fa-plus"></i>
        <% end %>
      </div>

      <div>
        <div class="section-empty hidden">No documents in this space</div>

        <ul data-controller="draggable" data-draggable-target="item" data-space-npi="<%= @space.npi %>">
          <%= render partial: "spaces/_sidebar/hierarchy_node", locals: { node: @space.hierarchy, level: 0 } %>
        </ul>
      </div>

      <div class="section-header-container">
        <div class="section-header-title">
          <i class="fa-regular fa-table"></i>
          Tables
        </div>

        <%= link_to_with_disable new_space_table_path(@space),
          disabled: !policy(@space).update? || true,
          class: "secondary-button" do
        %>
          <i class="fa-regular fa-plus"></i>
        <% end %>
      </div>

      <div>
        <div class="section-empty hidden">No tables in this space</div>

        <ul>
          <% @tables.each do |table| %>
            <% if table.id.to_s == params.dig(:object, :id) && table.class.to_s == params.dig(:object, :type) %>
              <% selected = true %>
            <% end %>

            <li class="relative w-64 group/table-item-link">
              <%= link_to space_table_path(@space, table), class: "flex flex-row h-9 #{ selected ? "group-hover/table-item-link:bg-blue-200 group-hover/table-item-link:active:bg-blue-300 bg-blue-100" : "group-hover/table-item-link:bg-gray-100 group-hover/table-item-link:active:bg-gray-200"}" do %>
                <div class="flex flex-row items-center w-full">
                  <div class="mx-2.5">•</div>
                  <div class="text-left pr-16 truncate">
                    <%= table.name %>
                  </div>
                </div>
              <% end %>

              <%= render partial: "spaces/_sidebar/sidebar_edit_link", locals: { edit_path: edit_space_table_path(@space, table), selected: selected } %>

              <%= link_to space_table_path(@space, table), data: { turbo_method: :delete, turbo_confirm: "Are you sure? Deleted table cannot be restored." }, class: "absolute right-1 top-1 rounded-md size-7 p-1 #{ selected ? "hover:bg-blue-300 active:bg-blue-400" : "hover:bg-gray-200 active:bg-gray-300"}" do %>
                <div class="group-hover/table-item-link:opacity-30 opacity-0 transition-opacity duration-300 bg-gray-950 size-5 icon-[heroicons--trash]"></div>
              <% end %>
            </li>
          <% end %>
        </ul>
      </div>

      <div class="mt-auto self-end">
        <div class="flex items-center my-4">
          <span class="mr-2">Show archived:</span>
          <%= render partial: "application/components/toggle_button", locals: { checked: cookies["ikigai_userPreferences_showArchived"] == "true" } %>
        </div>
      </div>
    </div>
  </div>
<% end %>

<%= turbo_frame_tag "new_object_comment" do %>
  <%= form_with scope: :reaction,
    url: new_resource_comment_path(resource),
    method: :post,
    data: { turbo_frame: "new_object_comment" } do |f|
  %>
    <%= f.hidden_field :emoji, data: { emoji_picker_target: "emojiInput" }, onchange: "this.form.requestSubmit()" %>

    <button class="create-reaction-button" data-action="click->emoji-picker#showPicker">
      <i class="fa-sharp fa-solid fa-face-awesome"></i>
    </button>

    <div data-emoji-picker-target="pickerContainer"></div>
  <% end %>
<% end %>
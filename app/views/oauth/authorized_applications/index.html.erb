<% content_for :focused_header do %>
  Connected Applications
<% end %>

<% content_for :focused_content do %>
  <div class="table-legend">
    <div class="table-legend-description">
      <p>Applications that have been authorized to access your Fundamento workspace.</p>
    </div>
  </div>

  <% if @applications.empty? %>
    <p class="text-gray-500 dark:text-gray-400 text-sm mt-4">No applications connected.</p>
  <% else %>
    <table class="table-list">
      <thead>
        <tr>
          <th scope="col">Application</th>
          <th scope="col">Action</th>
        </tr>
      </thead>
      <tbody>
        <% @applications.each do |app| %>
          <tr>
            <th scope="row">
              <div class="text-base font-semibold"><%= app.name %></div>
            </th>
            <td>
              <%= button_to "Revoke",
                oauth_authorized_application_path(app),
                method: :delete,
                class: "link-button",
                form: { data: { turbo_confirm: "Revoke access for #{app.name}? The app will need to re-authorize." } }
              %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% end %>
<% end %>

<%= render "focused_section" %>

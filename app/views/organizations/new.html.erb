<section class="form-section">
  <h2 class="form-header">Create organization</h2>

  <div class="form-legend">
    <p>Organization can be used to manage documents and users in a single place. Once you create an organization you will be able to create and share documents with external collaborators.</p>

    <p>You don't need an organization to collaborate on documents you were invited to.</p>
  </div>

  <%= form_for(@organization, url: organizations_path,
    html: { class: "default-form" },
    data: { turbo: false, controller: "prevent-double-submit" }) do |f|
  %>
    <%= render "devise/shared/error_messages", resource: @organization %>

    <div class="form-field">
      <%= f.label :name %>
      <%= f.text_field :name, autofocus: true, class: "form-input" %>
    </div>

    <div class="form-footer">
      <%= link_to "Cancel", organizations_path, class: "secondary-button" %>
      <%= f.submit "Create", class: "form-submit" %>
    </div>
  <% end %>
</section>
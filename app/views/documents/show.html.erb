<% content_for :head do %>
  <meta name="turbo-cache-control" content="no-cache">
<% end %>

<% content_for :content_menu do %>
  <div id="editor-connection-indicator"></div>

  <% if (favorite = pundit_user.organization_user.favorites.find_by(object: @document)) %>
    <%= render partial: "favorites/destroy_favorite", locals: { object: @document, favorite: favorite } %>
  <% else %>
    <%= render partial: "favorites/create_favorite", locals: { object: @document } %>
  <% end %>

  <% has_permission_to_edit = policy(@document).update? %>
  <div data-controller="popover">
    <%= button_to "Edit",
      edit_document_path(@document),
      method: :get,
      disabled: !has_permission_to_edit,
      class: "primary-button document-toolbar-button",
      data: {controller: "hotkey", hotkey: "e", action: "mouseenter->popover#show mouseleave->popover#hide"}
    %>
    <template data-popover-target="content">
      <div data-popover-target="card" class="<%= has_permission_to_edit ? "hidden " : "" %>z-10 bg-gray-800 text-gray-50 text-xs p-2 w-24 flex flex-row items-center justify-center rounded absolute top-12">
        <p class="block">You have no permission to edit this document</p>
      </div>
    </template>
  </div>

  <div
    data-controller="dropdown"
    data-action="click@window->dropdown#hide touchstart@window->dropdown#hide keydown.esc->dropdown#hide"
    class="inline-block relative">

    <%= render partial: "public_links/document_share_button", locals: { public_link_exists: @document.public_link.present? } %>

    <div
      data-dropdown-target="menu"
      class="hidden absolute top-5 right-0 z-10 mt-5 flex w-screen max-w-max"
      role="dialog"
      aria-orientation="vertical"
      aria-labelledby="document_share_button">
      <div class="dropdown-container w-90">
        <%= turbo_frame_tag "document_share_dropdown", src: @document.public_link.present? ? public_link_path(@document.public_link, format: "turbo_stream") : new_public_link_path(public_link: { object_type: @document.class, object_id: @document.id }, format: "turbo_stream"), loading: "lazy" %>
      </div>
    </div>
  </div>

  <%= render partial: "content/document_menu", locals: { space: @space, content: @document } %>
<% end %>

<article class="document">
  <%= turbo_frame_tag "document_hierarchy",
    data: { turbo: false },
    src: hierarchy_document_path(@document) %>

  <%= react_component "ShowVersionPanel", {
    version: @version.attributes.except("id"),
    document: @document.attributes.except("sync"),
    space: @space.to_react_props
  } %>
</article>

<%= turbo_frame_tag "object_reactions", src: document_reactions_path(@document), loading: "lazy" %>

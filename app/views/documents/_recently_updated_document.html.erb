<div id="<%= dom_id(document) %>" class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600">

  <div class="p-2">
    <div class="text-base font-semibold">
      <%= link_to document.title, edit_space_document_path(document.space, document) %>
    </div>
    <div class="font-normal text-gray-500">Last updated <%= time_ago_in_words document.updated_at %></div>
  </div>
</div>
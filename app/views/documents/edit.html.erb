<div class="h-full grid grid-cols-[minmax(10px,300px)_minmax(10px,_3fr)]">
  <%= render 'application/left_side_bar' %>
  <article class="flex-col overflow-auto">
    <div class="bg-white h-12 flex justify-end items-center p-2">
      <%= button_to "Save this as version", space_document_versions_path(@space, @document), method: :create,
                    params: {blocks: ""},
                    :onclick => "this.form.elements['blocks'].value = JSON.stringify(window.blockNoteEditor?.document);",
                    class: "document-toolbar-button" %>

      <% if @document.archived %>
        <%= button_to "Restore", space_document_path(@space, @document), method: :put,
                      params: {document: {archived: false}},
                      form: {data: {turbo_confirm: 'Restore this document? This will make it visible in the default view.'}},
                      class: "document-toolbar-button" %>
      <% else %>
        <%= button_to "Archive", space_document_path(@space, @document), method: :put,
                      params: {document: {archived: true}},
                      form: {data: {turbo_confirm: 'Mark this document as archived? This will hide if from default view.'}},
                      class: "document-toolbar-button" %>
      <% end %>

      <%= button_to "Delete", space_document_path(@space, @document), method: :delete,
                    form: {data: {turbo_confirm: 'Are you sure? Deleted document cannot be restored.'}},
                    class: "document-toolbar-button" %>

      <div
        data-controller="dropdown"
        data-action="click@window->dropdown#hide touchstart@window->dropdown#hide keydown.esc->dropdown#hide"
        class="inline-block relative">

        <button data-action="dropdown#toggle:stop" class="document-toolbar-button">
          <svg xmlns="http://www.w3.org/2000/svg" class="fill-current h-4 w-4 mr-2" viewBox="0 0 512 512"><!--!Font Awesome Free 6.6.0 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free Copyright 2024 Fonticons, Inc.--><path d="M57.7 193l9.4 16.4c8.3 14.5 21.9 25.2 38 29.8L163 255.7c17.2 4.9 29 20.6 29 38.5l0 39.9c0 11 6.2 21 16 25.9s16 14.9 16 25.9l0 39c0 15.6 14.9 26.9 29.9 22.6c16.1-4.6 28.6-17.5 32.7-33.8l2.8-11.2c4.2-16.9 15.2-31.4 30.3-40l8.1-4.6c15-8.5 24.2-24.5 24.2-41.7l0-8.3c0-12.7-5.1-24.9-14.1-33.9l-3.9-3.9c-9-9-21.2-14.1-33.9-14.1L257 256c-11.1 0-22.1-2.9-31.8-8.4l-34.5-19.7c-4.3-2.5-7.6-6.5-9.2-11.2c-3.2-9.6 1.1-20 10.2-24.5l5.9-3c6.6-3.3 14.3-3.9 21.3-1.5l23.2 7.7c8.2 2.7 17.2-.4 21.9-7.5c4.7-7 4.2-16.3-1.2-22.8l-13.6-16.3c-10-12-9.9-29.5 .3-41.3l15.7-18.3c8.8-10.3 10.2-25 3.5-36.7l-2.4-4.2c-3.5-.2-6.9-.3-10.4-.3C163.1 48 84.4 108.9 57.7 193zM464 256c0-36.8-9.6-71.4-26.4-101.5L412 164.8c-15.7 6.3-23.8 23.8-18.5 39.8l16.9 50.7c3.5 10.4 12 18.3 22.6 20.9l29.1 7.3c1.2-9 1.8-18.2 1.8-27.5zM0 256a256 256 0 1 1 512 0A256 256 0 1 1 0 256z"/></svg>
          Share
        </button>

        <div data-dropdown-target="menu" class="hidden absolute top-5 right-0 z-10 mt-5 flex w-screen max-w-max">
          <div class="text-sm bg-white shadow-lg rounded border overflow-hidden w-90">
            <%= turbo_frame_tag "document_share_dropdown", src: @document.public_link.present? ? public_link_path(@document.public_link, format: "turbo_stream") : new_public_link_path(public_link: { object_type: @document.class, object_id: @document.id }, format: "turbo_stream"), loading: "lazy" %>
          </div>
        </div>
      </div>

    </div>
    <div class="bg-white overflow-auto">
      <%= react_component "EditDocumentPanel", {document: @document.attributes.except("sync"), space: @space, current_user: current_user} %>
    </div>
  </article>
</div>

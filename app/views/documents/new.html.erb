<div class="h-full grid grid-cols-[minmax(10px,300px)_minmax(10px,_3fr)]">
  <%= render 'application/left_side_bar_for_documents' %>
  <article>

    <h2 class="form-header">Create document</h2>

    <%= form_for(@document, url: space_documents_path(@space), html: { method: :post }) do |f| %>
      <%= f.hidden_field :space_id, value: @space.id %>

      <%= render "devise/shared/error_messages", resource: @document %>

      <div class="form-field">
        <%= f.label :title %><br />
        <%= f.text_field :title, autofocus: true, class: "form-input" %>
      </div>

      <div class="form-footer">
        <%= f.submit "Create", class: "form-submit" %>
      </div>
    <% end %>

  </article>
</div>

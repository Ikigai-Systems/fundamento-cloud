<%= turbo_stream_from ["teams_list", current_organization] %>

<% content_for :focused_header do %>
  Teams
<% end %>

<% content_for :focused_header_buttons do %>
  <% if policy(Team).create? %>
    <div class="mt-4 flex md:ml-4 md:mt-0">
      <%= link_to 'Create', new_team_path, class: "secondary-button" %>
    </div>
  <% end %>
<% end %>

<% content_for :focused_content do %>
  <div class="sm:flex sm:items-center p-5">
    <div class="sm:flex-auto">
      <p class="mt-2 text-sm text-gray-700">A list of all teams in your organization.</p>
    </div>
  </div>

  <table class="table-list">
    <thead>
      <tr>
        <th scope="col" class="px-6 py-3">
          Name
        </th>
        <th scope="col" class="px-6 py-3">
          Action
        </th>
      </tr>
    </thead>
    <tbody id="teams">
      <% @teams.each do |team| %>
        <%= render partial: team %>
      <% end %>
    </tbody>
  </table>
<% end %>

<%= render "focused_section" %>
<section class="form-section">
  <h2 class="form-header">Edit team <%= @team.name %></h2>

  <%= form_for(@team, data: { turbo: false }) do |f| %>
    <%= render "devise/shared/error_messages", resource: @team %>

    <div class="form-field">
      <%= f.label :name %><br/>
      <%= f.text_field :name, autofocus: true, class: "form-input" %>
    </div>

    <div class="form-field">
      <%= f.label :shortcut %><br/>
      <%= f.text_field :shortcut, autofocus: true, class: "form-input" %>
    </div>

    <div class="form-field">
      <%= f.label :team_members %><br/>

      <div
          data-controller="multiselect"
          data-multiselect-selected-value="<%= team_memberships_to_multiselect_value(@team) %>"
          data-multiselect-search-url-value="<%= suggest_members_teams_path %>"
          data-placeholder="Search for members..."
          data-no-results-message="Nothing matches">

        <%= f.select :team_memberships, [], { multiple: true }, { class: "multiselect__hidden", data: { multiselect_target: "hidden" } } %>
      </div>
    </div>

    <div class="form-footer">
      <%= link_to "Cancel", team_path(@team), class: "secondary-button" %>
      <%= f.submit "Save", class: "form-submit" %>
    </div>
  <% end %>
</section>
<section class="form-section">
  <h2 class="form-header">Accept invitation to <%= resource.organization.name %></h2>

  <%= form_for(resource, as: resource_name, url: invitation_path(resource_name),
    html: { method: :put, class: "default-form" }) do |f|
  %>
    <%= render "devise/shared/error_messages", resource: resource %>

    <%= f.hidden_field :invitation_token, readonly: true %>

    <div class="form-field">
      <%= f.label :first_name %>
      <%= f.text_field :first_name, class: "form-input"  %>
    </div>

    <div class="form-field">
      <%= f.label :last_name %>
      <%= f.text_field :last_name, class: "form-input"  %>
    </div>

    <% if f.object.class.require_password_on_accepting %>
      <div class="form-field">
        <%= f.label :password %>
        <%= f.password_field :password, class: "form-input" %>
      </div>

      <div class="form-field">
        <%= f.label :password_confirmation %>
        <%= f.password_field :password_confirmation, class: "form-input" %>
      </div>
    <% end %>

    <div class="form-footer">
      <%= f.submit "Create an account", class: "form-submit" %>
    </div>
  <% end %>
</section>
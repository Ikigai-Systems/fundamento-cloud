<section class="form-section">
  <% case @state %>
  <% when :wrong_user_logged_in %>
    <%# State 1: User is logged in but with wrong email %>
    <h2 class="form-header">Account Mismatch</h2>

    <div class="form-legend">
      <p>
        <% if resource.invited_by.present? %><%= resource.invited_by.display_name %> invited you
        <% else %>You've been invited
        <% end %> to join <strong><%= @organization.name %></strong>.
      </p>

      <p>You're signed in as <strong><%= current_user.email %></strong>, but this invitation is for
        <strong><%= @invited_email %></strong></p>

      <p>To accept this invitation you need to sign out from the current session.</p>
    </div>

    <div class="form-footer">
      <%= button_to "Sign out", destroy_user_session_path, method: :delete,
        params: { return_to: accept_invited_user_invitation_path(invitation_token: resource.invitation_token) },
        class: "form-submit" %>
    </div>

  <% when :already_member %>
    <%# State 2: User is already a member of the organization %>
    <h2 class="form-header">Invitation accepted</h2>

    <div class="form-legend">
      <p>You're already a member of <strong><%= @organization.name %></strong>.</p>
    </div>

    <div class="form-footer">
      <%= link_to "Go to #{@organization.name}", organization_path(@organization), class: "form-submit" %>
    </div>

  <% when :logged_in_ready %>
    <%# State 3: User is logged in with correct email, ready to accept %>
    <h2 class="form-header">Accept invitation</h2>

    <div class="form-legend">
      <p>
        <% if resource.invited_by.present? %><%= resource.invited_by.display_name %> invited you
        <% else %>You've been invited
        <% end %> to join <strong><%= @organization.name %></strong>.
      </p>

      <p>Continuing as <%= current_user.display_name %> (<%= current_user.email %>)</p>
    </div>

    <%= form_for(resource, as: resource_name, url: invitation_path(resource),
      html: { method: :put, class: "default-form" }) do |f| %>

      <%= f.hidden_field :invitation_token, value: resource.invitation_token %>

      <div class="form-footer">
        <%= f.submit "Accept", class: "form-submit" %>
      </div>
    <% end %>

    <div class="text-center mt-4">
      <%= link_to "Not you? Sign out", destroy_user_session_path, method: :delete,
        data: { turbo_method: :delete },
        class: "text-sm text-gray-600 hover:text-gray-900" %>
    </div>

  <% when :existing_user_not_logged_in %>
    <%# State 4: User exists but is not logged in %>
    <h2 class="form-header">Accept invitation</h2>

    <div class="form-legend">
      <p>
        <% if resource.invited_by.present? %><%= resource.invited_by.display_name %> invited you
        <% else %>You've been invited
        <% end %> to join <strong><%= @organization.name %></strong>.</p>

      <p>You already have a Fundamento account with this email address. Do you want to accept the invitation?</p>
    </div>

    <%= form_for(resource, as: resource_name, url: invitation_path(resource_name),
      html: { method: :put, class: "default-form", data: { turbo: false } }) do |f| %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <%= f.hidden_field :invitation_token, readonly: true %>

      <div class="form-footer">
        <%= f.submit "Accept & sign in", class: "form-submit" %>
      </div>
    <% end %>

  <% else %>
    <%# State 5: New user (doesn't have an account) - Passwordless flow %>
    <h2 class="form-header">Accept invitation</h2>

    <div class="form-legend">
      <p>
        <% if resource.invited_by.present? %><%= resource.invited_by.display_name %> invited you
        <% else %>You've been invited
        <% end %> to collaborate in <strong><%= @organization.name %></strong> an organization on <%=link_to "Fundamento", "https://fundamento.it" %>.</p>

      <p>Fundamento is a free collaborative workspace for teams.</p>
    </div>

    <%= form_for(resource, as: resource_name, url: invitation_path(resource_name),
      html: { method: :put, class: "default-form" }) do |f|
    %>
      <%= render "devise/shared/error_messages", resource: resource %>

      <%= f.hidden_field :invitation_token, readonly: true %>

      <div class="form-footer">
        <%= f.submit "Accept & create free account", class: "form-submit" %>
      </div>

      <div class="form-hint text-center">
        By accepting, you agree to our <%= link_to "Terms of Service", "https://fundamento.it/terms-and-conditions" %>
      </div>
    <% end %>
  <% end %>
</section>

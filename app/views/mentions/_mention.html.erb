<div id="<%= "mention_#{mention.mention_id}" %>">
  <div class="p-2 flex items-start gap-3">
    <div>
      <%= render ObjectIcon.new(object: Document.new, emoji: mention.try(:object_title_emoji)) %>
    </div>
    <div>
      <div class="text-base font-semibold truncate">
        <%= link_to mention.try(:object_title_emojiless) || mention.try(:object_title), mention.object_path %>
      </div>
      <div class="font-normal text-gray-500">Mentioned <%= time_ago_in_words mention.created_at %> ago</div>
    </div>
  </div>
</div>

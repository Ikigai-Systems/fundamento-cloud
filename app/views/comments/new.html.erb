<%= turbo_frame_tag "new_object_comment" do %>
  <%= form_with scope: :comment,
    url: comments_path(object_gid: @resource.to_gid_param),
    method: :post,
    html: {
      class: "default-form mb-3",
      data: {
        controller: "serialize-blocknote",
        "serialize-blocknote-editor-value": "commentEditor",
      }

    },
    data: { turbo_frame: "new_object_comment" } do |f|
  %>
    <%= render "devise/shared/error_messages", resource: @comment %>

    <%= f.hidden_field :content, data: { target: "serialize-blocknote.field" } %>

    <div class="flex flex-col gap-3">
      <div class="rounded-xl py-3 border min-h-[10rem] flex flex-col">
        <%= react_component "EditCommentPanel", {
          object: @resource.to_react_props,
          space: @resource.space.to_react_props,
        }, class: "flex flex-col flex-1" %>
      </div>

      <div class="flex gap-2">
        <%= f.submit "Add", class: "primary-button" %>
        <button type="button"
                class="secondary-button"
                onclick="this.closest('turbo-frame').innerHTML = ''">
          Cancel
        </button>
      </div>
    </div>
  <% end %>
<% end %>
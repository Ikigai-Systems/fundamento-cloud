<section class="form-section">
  <h2 class="form-header">Create API Token</h2>

  <%= form_for(@api_token, url: user_api_tokens_path(current_user),
    html: { class: "default-form" },
    data: { turbo: false, controller: "prevent-double-submit" }) do |f|
  %>
    <%= render "devise/shared/error_messages", resource: @api_token %>

    <div class="form-field">
      <%= f.label :title %>
      <%= f.text_field :title, autofocus: true, class: "form-input" %>
    </div>

    <div class="form-footer">
      <%= link_to "Cancel", user_api_tokens_path(current_user), class: "secondary-button" %>
      <%= f.submit "Create", class: "form-submit" %>
    </div>
  <% end %>
</section>
<%= turbo_frame_tag "shared_frame" do %>
  <%= turbo_stream_from [current_user, "shared"] %>

  <div id="shared_container">
    <div id="shared_list">
      <% @shared.each do |public_link| %>
        <div id="<%= dom_id(public_link) %>" class="flex p-2 items-start gap-3">
          <div>
            <%= render ObjectIcon.new(object: public_link.object) %>
          </div>
          <div>
            <div class="text-base font-semibold truncate">
              <%= link_to public_link.object.try(:title_emojiless) || public_link.object.try(:title), public_url(public_link.npi) %>
            </div>
            <div class="font-normal text-gray-500 dark:text-gray-400">Last updated <%= time_ago_in_words public_link.updated_at %></div>
          </div>
        </div>
      <% end %>
    </div>

    <% if @shared.empty? %>
      <div class="flex items-center justify-start p-5">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="w-12 h-12 text-gray-500 mr-4">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4m-2 0V6a2 2 0 00-2-2h-4a2 2 0 00-2 2v4h4m6 0a2 2 0 11-2 2 2 2 0 012-2z"></path>
        </svg>
        <div>
          <h2 class="text-gray-600 text-2xl">No documents to review</h2>
          <p class="text-gray-500">We couldn't find any documents you have been asked to review.</p>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
<%= turbo_frame_tag "recently_updated_frame" do %>
  <%= turbo_stream_from [current_organization, "recently_updated"] %>

  <div id="recently_updated_container">
    <div id="recently_updated_list">
      <% @recently_updated.each do |object| %>
        <div id="<%= dom_id(object) %>" class="flex p-2 items-start gap-3">
          <div>
            <% if object.class == Document %>
              <i class="fa-regular fa-file-lines"></i>
            <% elsif object.class == Table %>
              <i class="fa-regular fa-table"></i>
            <% end %>
          </div>
          <div>
            <div class="text-base font-semibold truncate">
              <%= link_to object.title, polymorphic_path(object) %>
            </div>
            <div class="font-normal text-gray-500">Last updated <%= time_ago_in_words object.updated_at %></div>
          </div>
        </div>
      <% end %>
    </div>

    <% if @recently_updated.empty? %>
      <div class="flex items-center justify-start p-5">
        <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="w-12 h-12 text-gray-500 mr-4">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4m-2 0V6a2 2 0 00-2-2h-4a2 2 0 00-2 2v4h4m6 0a2 2 0 11-2 2 2 2 0 012-2z"></path>
        </svg>
        <div>
          <h2 class="text-gray-600 text-2xl">No recent documents or tables</h2>
          <p class="text-gray-500">We couldn't find any documents or tables.</p>
        </div>
      </div>
    <% end %>
  </div>
<% end %>
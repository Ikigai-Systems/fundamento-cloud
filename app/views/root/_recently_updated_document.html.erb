<div id="<%= dom_id(document) %>">
  <div class="p-2">
    <div class="text-base font-semibold truncate">
      <%= link_to document.title, document_path(document) %>
    </div>
    <div class="font-normal text-gray-500">Last updated <%= time_ago_in_words document.updated_at %></div>
  </div>
</div>
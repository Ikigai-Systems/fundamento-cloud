<%= turbo_stream_from "recently_updated_documents_list" %>

<% recent_documents = current_organization.documents.recently_updated.limit(50) %>

<% recent_documents.each do |document| %>
  <div id="<%= dom_id(document) %>" class="bg-white border-b dark:bg-gray-800 dark:border-gray-700 hover:bg-gray-50 dark:hover:bg-gray-600">

    <div class="ps-3">
      <div class="text-base font-semibold"><%= document.title %></div>
      <div class="font-normal text-gray-500">Last updated <%= time_ago_in_words user.last_online_at %></div>
    </div>
  </div>
<% end %>

<% if recent_documents.empty? %>
  <div class="flex items-center justify-start">
    <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" class="w-12 h-12 text-gray-500 mr-4">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4m-2 0V6a2 2 0 00-2-2h-4a2 2 0 00-2 2v4h4m6 0a2 2 0 11-2 2 2 2 0 012-2z"></path>
    </svg>
    <div>
      <h2 class="text-gray-600 text-2xl">No recent documents</h2>
      <p class="text-gray-500">We couldn't find any documents.</p>
    </div>
  </div>
<% end %>

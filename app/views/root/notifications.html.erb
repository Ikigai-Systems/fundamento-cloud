<%= turbo_frame_tag :notifications do %>
  <% unread_mentions_count = current_organization_membership.unread_mentions_count(policy_scope(current_organization.documents)) %>

  <%# Make sure when updating link style you also update one in app/views/application/_notifications_menu.html.erb %>
  <%= link_to root_path(:anchor => "mentions"),
    title: "Notifications",
    class: "document-toolbar-button relative",
    role: "button",
    aria: { label: unread_mentions_count > 0 ? "Notifications, #{unread_mentions_count} unread" : "Notifications, no unread" },
    data: { testid: "notifications-button" } do %>

    <span class="icon-[heroicons--bell] size-5" aria-hidden="true"></span>

    <% if unread_mentions_count > 0 %>
      <span
        class="absolute inline-flex items-center justify-center w-6 h-6 text-xs font-bold text-white bg-red-500 border-2 border-white rounded-full -top-2 -end-2 dark:border-gray-900"
        role="status"
        aria-label="<%= unread_mentions_count %> unread mentions"
        data-testid="notification-badge"
        data-count="<%= unread_mentions_count %>"
      >
        <%= unread_mentions_count %>
      </span>
    <% else %>
      <%# Hidden status for screen readers when there are no notifications %>
      <span class="sr-only" role="status">No unread notifications</span>
    <% end %>
  <% end %>
<% end %>

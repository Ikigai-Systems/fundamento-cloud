[{"id":"11967447-ca5e-4656-b7da-4191f82c33d3","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Benefits:","styles":{}}],"children":[]},{"id":"3c82d2b6-fd43-408c-9b6e-647ab72b93b6","type":"checkListItem","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left","checked":false},"content":[{"type":"text","text":"You are able to create a fully personalised document using features provided by Fundamento.","styles":{}}],"children":[]},{"id":"6040b31f-b109-4a1c-b1cb-2a3e961fa2e9","type":"checkListItem","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left","checked":false},"content":[{"type":"text","text":"You can make Event plan, Product/Design/Marketing Brief, User Story, Workshop agenda, ToDo List, Meeting minutes or use case/test scenarios.","styles":{}}],"children":[]},{"id":"1ad9dd30-4423-47eb-893a-c80dfeaa2dc1","type":"checkListItem","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left","checked":false},"content":[{"type":"text","text":"You can send the result of your work to anybody i.e. work colleagues, your partner in order to ask their opinion an get their feedback, or just have it for yourself.","styles":{}}],"children":[]},{"id":"83cc6f75-27f2-4f69-8cb6-ec6ee3671902","type":"bulletListItem","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Creating a document","styles":{"bold":true}}],"children":[]},{"id":"c33aaa10-e993-4816-9906-1d972da7b3a6","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"In order to start writing/typing something, just click orange \"Edit\" button above","styles":{}}],"children":[]},{"id":"d7a4a382-7057-4a8f-8fa2-3af12777a940","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:407","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"d5e0ea8f-f7ee-46e8-a1b6-a61b1cad3616","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Newly created Document is in a ","styles":{}},{"type":"text","text":"DRAFT","styles":{"code":true}},{"type":"text","text":" mode.","styles":{}}],"children":[]},{"id":"e7cb3d45-28ac-45da-a700-73b6abec460b","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Any edit made to it is being instantly reflected to anyone else visiting that Document.","styles":{}}],"children":[]},{"id":"43d87d0e-a7bb-4971-9885-64d74fd13ba3","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"If you change a text from: \"Paragraph\" into \"Heading1 or 2 or 3\" you'll see that Structure of the document is being created (on the top-right)","styles":{}}],"children":[]},{"id":"6ff44723-c209-437d-a972-69309a93b349","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:408","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"a7ad393b-14e5-4b85-865a-edf97dd812ba","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"This allows rapid collaboration with other people on the initial versions of Documents.","styles":{}}],"children":[]},{"id":"c176d98f-16a7-4a7e-9dbb-08d1b98a4df6","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Until you or someone else don't click \"Update\" button, the document will stay in the Draft mode.","styles":{}}],"children":[]},{"id":"6668aa7c-d2f5-4287-8249-49e50f1e8f9f","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"At any time when you acknowledge a document as one that can be shown to others, you can save current version of your document using orange ","styles":{}},{"type":"text","text":"Update","styles":{"code":true}},{"type":"text","text":" button","styles":{}}],"children":[]},{"id":"1e9e01a3-5410-4b20-ae60-6f686424a579","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:409","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"cf2d1e41-f4a3-4b4e-b358-3c8a19643370","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"More about \"Draft version\" of your document:","styles":{}}],"children":[]},{"id":"49f0b2be-b0a4-49a5-b3c2-b29d7a55b565","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Your Team (see \"Team\" section) will be able to see it, make changes in it, and even if they do not click \"Update\" button, everyone can see what they have added/changed.","styles":{}}],"children":[]},{"id":"8dfcc8dd-2b4b-46be-87a3-1ef582816224","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"During typing you can also view actual/the latest version of the document using link provided: \"View current version\", don't worry, changes you have been made so far, are being stored and when you click once more \"Edit\" button you will see it (dać filmik)","styles":{}}],"children":[]},{"id":"f697cc43-5646-4168-815b-28150f4b8ba6","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"When you click \"Update\" - from now on, everyone visiting this Document will be directed to the most recent document Version in read-only mode. For further alter/reerange the contents of the Document users need to explicitly enter edit mode again by clicking ","styles":{}},{"type":"text","text":"Edit","styles":{"code":true}},{"type":"text","text":" button.","styles":{}}],"children":[]},{"id":"1bacf4b5-c1a2-44c0-aa84-21ccdd1618c4","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:410","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"9116121f-66da-47e8-ae12-9bbe4823e219","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"From now on everyone also can comment this document not interfering in the main section of the document. Comments will be shown in the separate section of the document (below main section and content of the document)","styles":{}}],"children":[]},{"id":"384cc330-35a0-4393-96c0-0bf0c87482e4","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"As you click \"Comments\" button you'll be able to create a comment.","styles":{}}],"children":[]},{"id":"79d8021a-3c5b-4c75-a62f-056f0da74cd7","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:411","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"01f3dd4d-21b1-488c-bc27-5908daaf337b","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"As you write a comment, you have to click \"Add\" button in order other to see it.","styles":{}}],"children":[]},{"id":"7f04a536-fa15-4456-8939-df4783f399d1","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:412","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"e9421eb2-fab7-4848-9be8-5f6800dfe727","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"As you can see, the comment is being published in the separate section of the document. Everyone can from now on also use an emoji showing their attitude towards the comment.","styles":{}}],"children":[]},{"id":"3a235731-3c05-4d5c-8aae-c5da1e5b69b8","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:413","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"e1c5cd22-f224-44ba-bc27-68fc9041de7b","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"You can create as many document Versions as you wish. To view Historical version of the document use ","styles":{}},{"type":"text","text":"•••","styles":{"code":true}},{"type":"text","text":" menu:","styles":{}}],"children":[]},{"id":"ebc4f1b3-65d0-4e41-b412-790cbe05adea","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:414","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"bf9b78bd-777a-49bd-811d-ff945c9c9dc6","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Thanks to the Historical versions everyone can see when the document has been created, changed and by whom.","styles":{}}],"children":[]},{"id":"835ed0da-fe0d-4f4d-a594-ac8a47e062b7","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:415","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"04729f5d-ffa3-461f-a087-7ae8d6d8e3d3","type":"bulletListItem","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Formatting a document","styles":{"bold":true}}],"children":[]},{"id":"eb28d2bf-5096-4f82-9117-4e266d7c5954","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"On the blank field on the left side of the paragraph you can see two icons: \"+\" and six dot ellipsis - these are here to help :)","styles":{}}],"children":[]},{"id":"caccab64-22c6-472c-9c36-7899eea44e0a","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:416","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"e32a8a88-1c49-4ea0-86ee-092a497348a9","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Let's focus on \"six dots\":","styles":{}}],"children":[]},{"id":"d6ad2d55-ca20-4acc-ac11-7a979a78ddac","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"As you hover over left side any text part you can see icons:","styles":{}}],"children":[]},{"id":"5c50a7bd-33a0-4325-9acc-13a3597cfdee","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"https://fundamento.cloud/attachments/369","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"21d94325-10b8-4889-9c60-ec18b7c17ac8","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Using this feature you can:","styles":{}}],"children":[]},{"id":"7004ae92-e724-4266-b0e3-2fe83adfc7fa","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"transforms the block into another type, change a text part info other format (as you can see now this part of the text is as \"Numbered list\")","styles":{}}],"children":[]},{"id":"57f7addc-0ae8-4c79-8910-761d151b0f24","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"https://fundamento.cloud/attachments/370","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"106a77e6-4ea8-4c25-ad2f-6a9284ac255a","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"You are also able to delete this part of document.","styles":{}}],"children":[]},{"id":"a8548fe6-8c1a-4c69-a230-d704e2dcc718","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Change a color ot he text itself or the background of the text (appears only for certain blocks)","styles":{}}],"children":[]},{"id":"53ff35d8-eaaa-437e-bfeb-2f56f2ac9e08","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:418","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"fe498ca9-0d24-4a8e-8d66-f5905431758f","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"With button \"+\" you can call up different features as: headings, basic blocks, media, emoji and advanced components like charts, formulas, or advanced tables.","styles":{}}],"children":[]},{"id":"33cd611f-bd29-4972-a573-8fccc5380d68","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Headings","styles":{"bold":true}},{"type":"text","text":" - use it when you want to quickly create a table of contents, change the document organization and format its design, make it easier for users to browse the document, highlight fragments of the document.","styles":{}}],"children":[]},{"id":"f35f5c6a-a703-4aaa-a0ee-8565e98ccf09","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:419","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"c9bbf080-75e7-49ee-ba1a-ce40e23574a2","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Heading 1","styles":{"code":true}},{"type":"text","text":": The largest heading, can be easily added with shortcut ","styles":{}},{"type":"text","text":"/h1","styles":{"code":true}},{"type":"text","text":" or CTRL+ALT+1","styles":{}}],"children":[]},{"id":"0577106e-addf-484e-ab88-b3086b586aaa","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Heading 2","styles":{"code":true}},{"type":"text","text":": The medium-sized heading, can be easily added with shortcut ","styles":{}},{"type":"text","text":"/h2","styles":{"code":true}},{"type":"text","text":" or CTRL+ALT+2","styles":{}}],"children":[]},{"id":"6edc645b-6d4a-4001-8479-2e984fe13bd9","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Heading 3","styles":{"code":true}},{"type":"text","text":": The smallest heading, can be easily added with shortcut ","styles":{}},{"type":"text","text":"/h3","styles":{"code":true}},{"type":"text","text":" or CTRL+ALT+3","styles":{}}],"children":[]},{"id":"62f3e69d-8a30-45b2-b706-a6dad9fce6af","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Basic blocks","styles":{"bold":true}},{"type":"text","text":" - use it when you want to can customize the look of your document by defining your own numbered, bulleted, and check lists.","styles":{}}],"children":[]},{"id":"6279afe8-de89-4aae-88ba-463e97d927eb","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:420","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"0c904075-8a96-4fc7-9b34-207a70c41123","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Numbered List","styles":{"code":true}},{"type":"text","text":": Indents your list and automatically generates the next number.","styles":{}}],"children":[]},{"id":"b93dcf57-9aa6-4ba6-9957-7fe6df186a4e","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Bullet List","styles":{"code":true}},{"type":"text","text":": Create part of a text as a bullets. Shortcut ","styles":{}},{"type":"text","text":"*","styles":{"code":true}},{"type":"text","text":" + ","styles":{}},{"type":"text","text":"space","styles":{"code":true}},{"type":"text","text":" (or ","styles":{}},{"type":"text","text":"-","styles":{"code":true}},{"type":"text","text":" + ","styles":{}},{"type":"text","text":"space","styles":{"code":true}},{"type":"text","text":", or ","styles":{}},{"type":"text","text":"+","styles":{"code":true}},{"type":"text","text":" + ","styles":{}},{"type":"text","text":"space","styles":{"code":true}},{"type":"text","text":")","styles":{}}],"children":[]},{"id":"4fdf2273-1293-4454-9ed3-893dd90cc33d","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Check List","styles":{"code":true}},{"type":"text","text":": Checkboxes for tasks and similar usage. Shortcut ","styles":{}},{"type":"text","text":"[]","styles":{"code":true}}],"children":[]},{"id":"f7d701f0-5530-4f47-a5e4-a144f4e497d8","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Paragraph","styles":{"code":true}},{"type":"text","text":": It's just your casual plain text.","styles":{}}],"children":[]},{"id":"5e69c394-b729-4ff2-aca5-dc49833b37b4","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Code","styles":{"code":true}},{"type":"text","text":": You can add a block of code in any language, complete with syntax coloring.","styles":{}}],"children":[]},{"id":"8c9c4290-8d9a-415d-8f24-7ce28edd5c80","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Examples of usage below:","styles":{}}],"children":[]},{"id":"d437639b-4951-4789-b95e-c19d169f321e","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Numbered list:","styles":{}}],"children":[]},{"id":"c8b7c3b0-8950-4286-8b4a-0f6b5b889988","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:421","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"fb344cf1-d06a-4ff8-9666-cea4e973b883","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Bullet List:","styles":{}}],"children":[]},{"id":"95c9ea74-28d0-4075-88b0-ac58356384e7","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:422","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"f209dfe9-822d-44e1-9479-73201f9e5fca","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Check List:","styles":{}}],"children":[]},{"id":"c5c0525e-d2ce-4451-9626-9b5de87b1250","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:423","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"b09f4c97-2750-4bfd-a0b8-f38fc69f7fab","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Paragraph:","styles":{}}],"children":[]},{"id":"9c5daf85-d7c5-4d1b-83fa-e86d21c3477c","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:424","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"671c4852-5fb2-41ea-9c85-b56726923bc3","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Code Block:","styles":{}}],"children":[]},{"id":"43587953-cc98-402a-ba03-83cbcd05dbd0","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"https://fundamento.cloud/attachments/379","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"20144a8a-3bcb-4a60-89e2-6ca3240a4867","type":"codeBlock","props":{"language":"javascript"},"content":[],"children":[]},{"id":"4bd82bcb-c1da-4a4e-9bbd-8b3bf0147ec8","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Media","styles":{"bold":true}},{"type":"text","text":" - use it in order to enrich the document with images, videos, files. As mamy says: *\"One image is worth a thousand words\" *sometimes is better just to show something rather than describe.","styles":{}}],"children":[]},{"id":"34194c29-5d64-4063-a5c4-2bf03d6ba9f1","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:425","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"e7cd4e92-e634-44c7-bad5-2846d8d8837e","type":"numberedListItem","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Add any ","styles":{}},{"type":"text","text":"image","styles":{"bold":true}},{"type":"text","text":" to show anything you need to mention.","styles":{}}],"children":[]},{"id":"fd51f945-b01b-4915-b345-e538d154f2f1","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Add image","styles":{}}],"children":[]},{"id":"7a2190ba-d0c6-44c4-bfd
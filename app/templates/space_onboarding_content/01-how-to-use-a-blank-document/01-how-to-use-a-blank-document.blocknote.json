,"backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Add any ","styles":{}},{"type":"text","text":"Audio","styles":{"bold":true}},{"type":"text","text":" to present others anything you need others to hear.","styles":{}}],"children":[]},{"id":"82685a03-3fbe-48cb-bcd2-c160a667b91c","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Add audio","styles":{}}],"children":[]},{"id":"13034b99-d0fb-4306-8ff2-13d02b37e587","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Upload an audio or embed it (showing after clicking \"Add audio\" field). Upload your own recording or embed from Spotify, Soundcloud etc.","styles":{}}],"children":[]},{"id":"a40a0573-af42-4a3f-9659-71f66c5f335a","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:429","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"e06b1e28-37d5-4d8d-a881-70c9cce598e0","type":"numberedListItem","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Add some file connected with the document somehow, e.g. to store it in an appropriate and convenient place.","styles":{}}],"children":[]},{"id":"d8b0b71e-2af4-4975-b50d-4b8b2c687156","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Add file","styles":{}}],"children":[]},{"id":"8aee0527-783e-4086-850e-615cc9588e06","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:430","caption":"","showPreview":true,"previewWidth":512},"children":[]}]
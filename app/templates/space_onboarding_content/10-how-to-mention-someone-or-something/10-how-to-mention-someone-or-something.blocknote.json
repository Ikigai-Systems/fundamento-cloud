  {
    "id": "afa81101-d54d-47c5-a1fd-ae453306a2f7",
    "type": "paragraph",
    "props": {
      "textColor": "default",
      "backgroundColor": "default",
      "textAlignment": "left"
    },
    "content": [
      {
        "type": "text",
        "text": "As you have created a document or a table and you want to mention someone or something in order to have somebody involved in the creating document or just your intention is that you want somebody to see something, you can use \"@\" function.",
        "styles": {}
      }
    ],
    "children": []
  },
  {
    "id": "fe2f5134-576f-4768-963c-e490a757f4de",
    "type": "paragraph",
    "props": {
      "textColor": "default",
      "backgroundColor": "default",
      "textAlignment": "left"
    },
    "content": [
      {
        "type": "text",
        "text": "You can both mention someone (and this person will receive a notification) or point out/mention another document in this Organization (that document will be linked here)",
        "styles": {}
      }
    ],
    "children": []
  },
  {
    "id": "4fff15b3-bcb6-44a3-b3aa-1ef5c33dbbfd",
    "type": "paragraph",
    "props": {
      "textColor": "default",
      "backgroundColor": "default",
      "textAlignment": "left"
    },
    "content": [],
    "children": []
  },
  {
    "id": "3fd8968b-9be3-4bb6-90ed-719e757bdd35",
    "type": "paragraph",
    "props": {
      "textColor": "default",
      "backgroundColor": "default",
      "textAlignment": "left"
    },
    "content": [
      {
        "type": "text",
        "text": "When someone has mentioned you in the document, you'll see a number of notifications (1, 2, etc.) on the icon on the top of the document page.",
        "styles": {}
      }
    ],
    "children": []
  },
  {

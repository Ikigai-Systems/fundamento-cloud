      "backgroundColor": "default",
      "textAlignment": "left"
    },
    "content": [
      {
        "type": "text",
        "text": "As a standard, this Notification icon looks like that:",
        "styles": {}
      }
    ],
    "children": []
  },
  {
    "id": "a37fee5b-c085-4ee2-aa39-798b92251be4",

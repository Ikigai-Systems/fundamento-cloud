      "textAlignment": "left",
      "checked": false
    },
    "content": [
      {
        "type": "text",
        "text": "For those who are not a very big fans of spreadsheets - probably our tables are better options than spreadsheets. Not likely for advanced data crunching, but to store all sorts of lists of objectives, key results, timelines, your inventory, data like tasks, even projects.",
        "styles": {}
      }
    ],
    "children": []
  },

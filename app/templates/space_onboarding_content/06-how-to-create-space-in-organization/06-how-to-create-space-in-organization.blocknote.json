[{"id":"9312ccd9-cf30-4cae-82b5-a69dad88a5d7","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Spaces organize your Documents and Tables into tree-like structures. Different people in your Organization can have different access permissions to your Spaces.","styles":{}}],"children":[]},{"id":"39cc4d7a-be8a-47e5-8458-e091af1a3eab","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"In order to create a new Space choose on the left side of the page a select button next to name of your Organization and then click \"Create space\"","styles":{}}],"children":[]},{"id":"9e82eaf3-73c1-48de-9841-141115284f93","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:439","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"05158127-6ebf-4893-a254-0263187bb7e4","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"Name this space and choose a mode access to this space.","styles":{}}],"children":[]},{"id":"69f2ceb5-4f4f-4bb9-ab6f-967a06443247","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"When you pick \"public\" - every person from the Organization will have an access to this space.","styles":{}}],"children":[]},{"id":"1a406877-68b1-467d-8827-475d91cc24c0","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"As you choose \"restricted\" - every document in this particular space will be ","styles":{}},{"type":"text","text":"visible","styles":{"bold":true}},{"type":"text","text":" to anyone within organization, but editable only to space managers or organization managers.","styles":{}}],"children":[]},{"id":"0861c157-b760-47ea-9ac3-2e5d9a6af2fe","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"When you decide on \"private\" - every document in this particular space will be ","styles":{}},{"type":"text","text":"visible","styles":{"bold":true}},{"type":"text","text":" and ","styles":{}},{"type":"text","text":"editable","styles":{"bold":true}},{"type":"text","text":" only to space managers or organization managers","styles":{}}],"children":[]},{"id":"2369c43e-10ce-4313-8e3f-d246de19d2dd","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:440","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"c6362c7b-73db-45ed-b07d-4cd725771b8f","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"In the last step you have to find and confirm who from your Organization should have an access to this specific space.","styles":{}}],"children":[]},{"id":"b61bb6e3-b88c-407d-821b-e90af85c3289","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:441","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"7e3661de-5307-4ffb-aae7-c7a6477fd030","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"As you have chosen a Team member with an access to this space, just click \"Create\" button","styles":{}}],"children":[]},{"id":"dee19bad-8ac4-49f8-9029-0de6ad474ffa","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:442","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"8900925e-db4b-4819-ab79-467ceb5b43db","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"In the next step you'll see that a new space has been successfuly created and you are in the \"start view\"","styles":{}}],"children":[]},{"id":"b033e01b-fa5e-4ac1-9da0-ff56c0564a44","type":"image","props":{"backgroundColor":"default","textAlignment":"left","name":"","url":"attachment:443","caption":"","showPreview":true,"previewWidth":512},"children":[]},{"id":"d43a1737-8c2a-463f-8aa5-7d086fdf47cc","type":"paragraph","props":{"textColor":"default","backgroundColor":"default","textAlignment":"left"},"content":[{"type":"text","text":"As for the moment, there is no possibiity to delete Space from right now, we are working on that","styles":{"italic":true}}],"children":[]}]
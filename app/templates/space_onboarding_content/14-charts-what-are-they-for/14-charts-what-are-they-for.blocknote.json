      "backgroundColor": "default",
      "textAlignment": "left"
    },
    "content": [
      {
        "type": "text",
        "text": "Visualizations of data can highlight insights to someone looking at the data for the first time, as well as important findings to others who won’t see the raw data. There are countless chart types out there, each with different use cases.",
        "styles": {}

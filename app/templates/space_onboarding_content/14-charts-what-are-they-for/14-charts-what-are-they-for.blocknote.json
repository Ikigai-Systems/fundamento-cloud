    },
    "content": [
      {
        "type": "text",
        "text": "Charts are a crucial part of working with data, since they are a way to compress and summarize at the same time large amounts of data into an easy to understand format. ",
        "styles": {}
      }
    ],
    "children": []
  },
  {

  {
    "id": "9c7f7a65-44d1-4859-acef-3f215bf78e60",
    "type": "paragraph",
    "props": {
      "textColor": "default",
      "backgroundColor": "default",
      "textAlignment": "left"
    },
    "content": [
      {
        "type": "text",
        "text": "Description\n",
        "styles": {
          "bold": true
        }
      },
      {
        "type": "text",
        "text": "Outputs contents of a specific cell for a current row. Use it in a Formula column types - elsewhere ",
        "styles": {}
      },
      {
        "type": "text",
        "text": "CurrentRow",
        "styles": {
          "code": true
        }
      },
      {
        "type": "text",
        "text": " will be invalid.\n",
        "styles": {}
      },
      {
        "type": "text",
        "text": "Arguments\n",
        "styles": {
          "bold": true
        }
      },
      {
        "type": "text",
        "text": "columnId",
        "styles": {
          "code": true
        }
      },
      {
        "type": "text",
        "text": " - An identifier representing uniquely the Column in the Table. For your convenience, Column name can be used as well.\n",
        "styles": {}
      },
      {
        "type": "text",
        "text": "Examples\n",
        "styles": {
          "bold": true
        }
      },
      {
        "type": "text",
        "text": "CurrentRow(\"First Name\"\")",
        "styles": {
          "code": true
        }
      },
      {
        "type": "text",
        "text": "→",
        "styles": {}
      },
      {
        "type": "text",
        "text": "\"Cris\"",
        "styles": {
          "code": true
        }
      }
    ],
    "children": []
  },
  {
    "id": "538e8a56-7f06-4d56-bb4e-3b289c223725",
    "type": "heading",
    "props": {
      "textColor": "default",
      "backgroundColor": "default",
      "textAlignment": "left",
      "level": 3
    },
    "content": [
      {
        "type": "text",
        "text": "AddRow (tableId, columnId, columnValue) ",
        "styles": {}
      },
      {
        "type": "text",
        "text": "ACTION",
        "styles": {
          "code": true
        }
      }
    ],
    "children": []
  },
  {
    "id": "5ec83f18-6480-4a1f-a85d-930408b06760",
    "type": "paragraph",
    "props": {
      "textColor": "default",
      "backgroundColor": "default",
      "textAlignment": "left"
    },
    "content": [
      {
        "type": "text",
        "text": "Description\n",
        "styles": {
          "bold": true
        }
      },
      {
        "type": "text",
        "text": "Adds a new row to a Fundamento Table. Optionally can fill value(s) in specified column(s).\n",
        "styles": {}
      },
      {
        "type": "text",
        "text": "Arguments\n",
        "styles": {
          "bold": true
        }
      },
      {
        "type": "text",
        "text": "tableId",
        "styles": {
          "code": true
        }
      },
      {
        "type": "text",
        "text": " - An identifier representing uniquely the Table in the Space. For your convenience, Table name can be used as well.\n",
        "styles": {}
      },
      {
        "type": "text",
        "text": "columnId...",
        "styles": {
          "code": true
        }
      },
      {
        "type": "text",
        "text": " - An identifier representing uniquely the Column in the Table. For your convenience, Column name can be used as well.\n",
        "styles": {}
      },
      {
        "type": "text",
        "text": "columnValue...",
        "styles": {
          "code": true
        }
      },
      {
        "type": "text",
        "text": " - value to use for specified Column when creating new Row.\n",
        "styles": {}
      },
      {
        "type": "text",
        "text": "Examples\n",
        "styles": {
          "bold": true
        }
      },
      {
        "type": "text",
        "text": "AddRow(\"Invoices\", \"Sale Date\", \"05/01/2024\")",
        "styles": {
          "code": true
        }
      }
    ],
    "children": []
  },
  {
    "id": "861d59e2-4181-4c74-a614-04edc7472cf0",
    "type": "heading",
    "props": {
      "textColor": "default",
      "backgroundColor": "default",
      "textAlignment": "left",
      "level": 3
    },
    "content": [
      {
        "type": "text",
        "text": "AddOrUpdateRow (tableId, criteria, columnId, columnValue) ",
        "styles": {}
      },
      {
        "type": "text",
        "text": "ACTION",
        "styles": {
          "code": true
        }
      }
    ],
    "children": []
  },
  {
    "id": "d45f2bf8-4332-4eb0-ae3b-6b7e999b6c05",
    "type": "paragraph",
    "props": {
      "textColor": "default",
      "backgroundColor": "default",
      "textAlignment": "left"
    },
    "content": [
      {
        "type": "text",
        "text": "Description\n",
        "styles": {
          "bold": true
        }
      },
      {
        "type": "text",
        "text": "Modifies all rows in a Fundamento Table matching the criteria. If no match is found, a new row will be inserted to Table.\n",
        "styles": {}
      },
      {
        "type": "text",
        "text": "Arguments\n",
        "styles": {
          "bold": true
        }
      },
      {
        "type": "text",
        "text": "tableId",
        "styles": {
          "code": true
        }
      },
      {
        "type": "text",
        "text": " - An identifier representing uniquely the Table in the Space. Table name can be used as well.\n",
        "styles": {}
      },
      {
        "type": "text",
        "text": "criteria",
        "styles": {
          "code": true
        }
      },
      {
        "type": "text",
        "text": " - Expression to select the rows for update\n",
        "styles": {}
      },
      {
        "type": "text",
        "text": "columnId",
        "styles": {
          "code": true
        }
      },
      {
        "type": "text",
        "text": " - An identifier representing uniquely the Column in the Table. Column name can be used as well.\n",
        "styles": {}
      },
      {
        "type": "text",
        "text": "columnValue",
        "styles": {
          "code": true
        }
      },
      {
        "type": "text",
        "text": " - value to use for specified Column when creating new Row.\n",
        "styles": {}
      },
      {
        "type": "text",
        "text": "Examples\n",
        "styles": {
          "bold": true
        }
      },
      {
        "type": "text",
        "text": "AddOrUpdateRow(\"Invoices\", CurrentRow(\"Sale Date\") == \"05/01/2024\", \"Sale Date\", \"05/01/2024\")",
        "styles": {
          "code": true
        }
      }
    ],
    "children": []
  },

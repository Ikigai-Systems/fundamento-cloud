  {
    "id": "26823c9a-55a9-4d30-ae0e-c52362f44d78",
    "type": "paragraph",
    "props": {
      "textColor": "default",
      "backgroundColor": "default",
      "textAlignment": "left"
    },
    "content": [
      {
        "type": "text",
        "text": "Description\n",
        "styles": {
          "bold": true
        }
      },
      {
        "type": "text",
        "text": "Outputs contents of a Fundamento Table in a form of JSON representation.",
        "styles": {}
      }
    ],
    "children": []
  },
  {
    "id": "da7671aa-85dc-4626-b2af-c9b4e152ea80",
    "type": "paragraph",
    "props": {
      "textColor": "default",
      "backgroundColor": "default",
      "textAlignment": "left"
    },
    "content": [
      {
        "type": "text",
        "text": "Rows from that Table will be converted to an array of objects, and each object consists of values of that row for the table columns.",
        "styles": {}
      }
    ],
    "children": []
  },
  {
    "id": "50f55a59-1d24-4bbf-9a00-2d82051c9a79",
    "type": "paragraph",
    "props": {
      "textColor": "default",
      "backgroundColor": "default",
      "textAlignment": "left"
    },
    "content": [
      {
        "type": "text",
        "text": "Objects will have duplicate key-value entries: one using column display name, and second using immutable identifier of the column (i.e. ",
        "styles": {}
      },
      {
        "type": "text",
        "text": "{\"First Name\": \"Cris\", \"9IJo5SGMLL\": \"Cris\"}",
        "styles": {
          "code": true
        }
      },
      {
        "type": "text",
        "text": ").\n",
        "styles": {}
      },
      {
        "type": "text",
        "text": "Arguments\n",
        "styles": {
          "bold": true
        }
      },
      {
        "type": "text",
        "text": "tableId",
        "styles": {
          "code": true
        }
      },
      {
        "type": "text",
        "text": " - An identifier representing uniquely the Table in the Space. For your convenience, Table name can be used as well.\n",
        "styles": {}
      },
      {
        "type": "text",
        "text": "Examples\n",
        "styles": {
          "bold": true
        }
      },
      {
        "type": "text",
        "text": "Table(\"Invoices\")",
        "styles": {
          "code": true
        }
      },
      {
        "type": "text",
        "text": "→",
        "styles": {}
      },
      {
        "type": "text",
        "text": "[{\"Invoice No\": \"PITU/01/2024\", \"First Name\": \"Cris\", \"Sale Date\": \"05/01/2024\", \"IAmount\": 100000}]",
        "styles": {
          "code": true
        }
      }
    ],
    "children": []
  },
  {
    "id": "339280e6-9c6d-42a8-b472-a93355f8125b",

{
  "name": "blocknote-converter",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "npx esbuild --bundle --external:canvas --external:jsdom --external:happy-dom --loader:.css=empty --loader:.tsx=tsx --jsx=automatic --platform=node src/index.ts --outfile=build/blocknoteConverter.cjs --format=cjs --alias:rowstack=../../vendor/javascript/rowstack/main.js",
    "build:watch": "npm run build -- --watch",
    "server": "nodemon -w build build/blocknoteConverter.cjs server",
    "server:watch": "concurrently -k -n build,server -c yellow.bold,cyan.bold \"npm run build:watch\" \"npm run server\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@esbuild-plugins/tsconfig-paths": "^0.1.2",
    "@fastify/formbody": "^8.0.1",
    "@fastify/request-context": "^6.2.1",
    "@sentry/node": "^10.28.0",
    "@vitest/ui": "^3.2.6",
    "commander": "^13.0.0",
    "concurrently": "^9.1.0",
    "esbuild": "^0.27.0",
    "esbuild-register": "^3.6.0",
    "happy-dom": "^20.0.11",
    "jsdom": "^27.3.0",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.6"
  },
  "dependencies": {
    "@blocknote/server-util": "^0.51.4",
    "@types/node": "^24.10.0",
    "fastify": "^5.1.0",
    "hast-util-to-html": "^9.0.5",
    "rehype-parse": "^9.0.1",
    "rehype-raw": "^7.0.0",
    "rehype-remark": "^10.0.1",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "remark-stringify": "^11.0.0",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.0.0",
    "yjs": "^13.6.28"
  },
  "packageManager": "npm@11.6.2"
}

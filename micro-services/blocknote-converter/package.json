{
  "name": "blocknote-converter",
  "version": "1.0.0",
  "type": "module",
  "main": "src/blocknoteServer.mjs",
  "scripts": {
    "build": "npx esbuild --bundle --external:canvas --external:jsdom --loader:.css=empty --platform=node src/index.ts --outfile=build/blocknoteConverter.cjs --format=cjs --alias:rowstack=../../vendor/javascript/rowstack/main.js",
    "server:build": "node build.mjs",
    "server:build:watch": "node build.mjs --watch",
    "server:run": "node build/blocknoteServer.js",
    "server:run:watch": "nodemon build/blocknoteServer.js",
    "dev": "concurrently -k -n esbuild,server -c yellow.bold,cyan.bold \"npm run server:build:watch\" \"npm run server:run:watch\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "@esbuild-plugins/tsconfig-paths": "^0.1.2",
    "@fastify/formbody": "^8.0.1",
    "@vitest/ui": "^3.2.4",
    "commander": "^13.0.0",
    "concurrently": "^9.1.0",
    "esbuild": "^0.27.0",
    "esbuild-register": "^3.6.0",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.3",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@blocknote/server-util": "^0.27.0",
    "@types/node": "^24.10.0",
    "fastify": "^5.1.0"
  },
  "packageManager": "npm@11.6.2"
}
